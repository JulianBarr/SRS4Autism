srs-inst:gp-a2-060-emphasizing-quantity-with-dou a srs-kg:GrammarPoint ;
    rdfs:label "Emphasizing quantity with 'dou'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "You can use 都 (dōu) to emphasize the large quantity of something, such as a group of people. The subject should be a large group (like '很多人', '大家') or refer to a recurring event (like '每天')."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-060-emphasizing-quantity-with-dou-001,
        srs-inst:sent-gp-a2-060-emphasizing-quantity-with-dou-002,
