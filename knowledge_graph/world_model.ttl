    srs-kg:pinyin "Nǐ de tóufa hé wǒ de tóufa yīyàng cháng." ;
    srs-kg:translationEN "You hair is as long as mine."@en .

srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-010 a srs-kg:Sentence ;
    rdfs:label "这里的天气跟我老家一样舒服。"@zh ;
    srs-kg:containsWord srs-kg:word-%E6%88%91,
        srs-kg:word-%E8%BF%99%E9%87%8C ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-073-basic-comparisons-with-yiyang ;
    srs-kg:pinyin "Zhèlǐ de tiānqì gēn wǒ lǎojiā yīyàng shūfu." ;
    srs-kg:translationEN "The weather here is just as comfortable as my hometown's."@en .

srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-011 a srs-kg:Sentence ;
