srs-inst:gp-a2-090-when-with-de-shihou a srs-kg:GrammarPoint ;
    rdfs:label "\"When\" with \"de shihou\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "的时候 (de shíhou) is used to mean 'when' or 'at the time of'. It is attached to a verb, adjective, or noun phrase that specifies a time or condition, creating a time clause that sets the context for the main clause of the sentence."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-090-when-with-de-shihou-001 ;
    srs-kg:structure "Time/Action/State + 的时候, [main clause]" .

srs-inst:sent-gp-a1-001-basic-sentence-structure-001 a srs-kg:Sentence ;
    rdfs:label "你 吃。"@zh ;
    srs-kg:containsWord srs-kg:word-%E4%BD%A0,
        srs-kg:word-%E5%90%83 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-001-basic-sentence-structure ;
    srs-kg:pinyin "Nǐ chī." ;
    srs-kg:translationEN "You eat."@en .

srs-inst:sent-gp-a1-001-basic-sentence-structure-002 a srs-kg:Sentence ;
    rdfs:label "他 笑。"@zh ;
