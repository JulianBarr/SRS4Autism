        srs-kg:word-%E7%AC%91 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-001-basic-sentence-structure ;
    srs-kg:pinyin "Tā xiào." ;
    srs-kg:translationEN "He laughs."@en .

srs-inst:sent-gp-a1-001-basic-sentence-structure-003 a srs-kg:Sentence ;
