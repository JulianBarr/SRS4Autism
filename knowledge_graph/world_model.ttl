    srs-kg:pinyin "Nǐ gěi wǒ dǎ diànhuà de shíhou, wǒ zhèngzài gēn péngyou hējiǔ." ;
    srs-kg:translationEN "When you called me, I was drinking with friends."@en .

srs-inst:sent-gp-a2-070-negative-commands-with-bie-001 a srs-kg:Sentence ;
    rdfs:label "别走。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-070-negative-commands-with-bie ;
    srs-kg:pinyin "Bié zǒu." ;
    srs-kg:translationEN "Don't leave."@en .

srs-inst:sent-gp-a2-070-negative-commands-with-bie-002 a srs-kg:Sentence ;
