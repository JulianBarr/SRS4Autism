    srs-kg:pinyin "Bié xiào!" ;
    srs-kg:translationEN "Don't laugh!"@en .

srs-inst:sent-gp-a2-070-negative-commands-with-bie-004 a srs-kg:Sentence ;
    rdfs:label "别动！"@zh ;
