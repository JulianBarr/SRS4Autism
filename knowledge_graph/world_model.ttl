    srs-kg:translationEN "Yesterday was cold, and today is also cold."@en .

srs-inst:sent-gp-a1-011-the-also-adverb-ye-%E4%B9%9F-022 a srs-kg:Sentence ;
    rdfs:label "他 生气 了 ？ 我 也 很 生气！"@zh ;
