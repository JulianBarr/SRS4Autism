@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix srs-inst: <http://srs4autism.com/instance/> .
@prefix srs-kg: <http://srs4autism.com/schema/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

srs-kg:Character a rdfs:Class ;
    rdfs:comment "A single Chinese character (汉字)." ;
    rdfs:subClassOf srs-kg:KnowledgePoint .

srs-kg:Concept a rdfs:Class ;
    rdfs:comment "A language-agnostic concept hub, e.g., from WordNet." .

srs-kg:GrammarPoint a rdfs:Class ;
    rdfs:comment "A grammar rule, from Chinese Grammar Wiki." ;
    rdfs:subClassOf srs-kg:KnowledgePoint .

srs-kg:KnowledgePoint a rdfs:Class ;
    rdfs:comment "A base class for any atomic, learnable concept." .

srs-kg:Sentence a rdfs:Class ;
    rdfs:comment "An example sentence, e.g., from Tatoeba." .

srs-kg:Word a rdfs:Class ;
    rdfs:comment "A multi-character word (词)." ;
    rdfs:subClassOf srs-kg:KnowledgePoint .

srs-inst:gp-a1-018-expressing-numbers-11-19-teens a srs-kg:GrammarPoint ;
    rdfs:label "Expressing numbers 11-19 (Teens)"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "Numbers from eleven to nineteen are formed with 十 (shí) followed by a digit from 一 (yī) to 九 (jiǔ)."@en ;
    srs-kg:structure "十 + x" .

srs-inst:sent-gp-a1-002-Forming%20questions%20with%20%27ma%27%20%28%E5%90%97%29-001 a srs-kg:Sentence ;
    rdfs:label "他 是 老师 吗？"@zh ;
    srs-kg:containsWord srs-kg:word-%E4%BB%96,
        srs-kg:word-%E8%80%81%E5%B8%88 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-002-Forming%20questions%20with%20%27ma%27%20%28%E5%90%97%29 ;
    srs-kg:pinyin "Tā shì lǎoshī ma?" ;
    srs-kg:translationEN "Is he a teacher?"@en .

srs-inst:sent-gp-a1-002-Forming%20questions%20with%20%27ma%27%20%28%E5%90%97%29-002 a srs-kg:Sentence ;
    rdfs:label "你 喜欢 咖啡 吗？"@zh ;
    srs-kg:containsWord srs-kg:word-%E4%BD%A0,
        srs-kg:word-%E5%96%9C%E6%AC%A2 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-002-Forming%20questions%20with%20%27ma%27%20%28%E5%90%97%29 ;
    srs-kg:pinyin "Nǐ xǐhuan kāfēi ma?" ;
    srs-kg:translationEN "Do you like coffee?"@en .

srs-inst:sent-gp-a1-002-Forming%20questions%20with%20%27ma%27%20%28%E5%90%97%29-003 a srs-kg:Sentence ;
    rdfs:label "他 是 机器人 吗？"@zh ;
    srs-kg:containsWord srs-kg:word-%E4%BB%96,
        srs-kg:word-%E6%9C%BA%E5%99%A8%E4%BA%BA ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-002-Forming%20questions%20with%20%27ma%27%20%28%E5%90%97%29 ;
    srs-kg:pinyin "Tā shì jīqìrén ma?" ;
    srs-kg:translationEN "Is he a robot?"@en .

srs-inst:sent-gp-a1-003-Forming%20%27what%20about...%3F%27%20questions%20with%20%27ne%27%20%28%E5%91%A2%29-001 a srs-kg:Sentence ;
    rdfs:label "我 吃 饭 了 。 你 呢？"@zh ;
    srs-kg:containsWord srs-kg:word-%E4%BD%A0,
        srs-kg:word-%E6%88%91 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-003-Forming%20%27what%20about...%3F%27%20questions%20with%20%27ne%27%20%28%E5%91%A2%29 ;
    srs-kg:pinyin "Wǒ chī fàn le. Nǐ ne?" ;
    srs-kg:translationEN "I've eaten. What about you?"@en .

srs-inst:sent-gp-a1-003-Forming%20%27what%20about...%3F%27%20questions%20with%20%27ne%27%20%28%E5%91%A2%29-002 a srs-kg:Sentence ;
    rdfs:label "北京 下 雨 了 。 上海 呢？"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-003-Forming%20%27what%20about...%3F%27%20questions%20with%20%27ne%27%20%28%E5%91%A2%29 ;
    srs-kg:pinyin "Běijīng xià yǔ le. Shànghǎi ne?" ;
    srs-kg:translationEN "It's raining in Beijing. How about Shanghai?"@en .

srs-inst:sent-gp-a1-003-Forming%20%27what%20about...%3F%27%20questions%20with%20%27ne%27%20%28%E5%91%A2%29-003 a srs-kg:Sentence ;
    rdfs:label "你 说 他们 可以 去 。 我们 呢？"@zh ;
    srs-kg:containsWord srs-kg:word-%E4%BB%96%E4%BB%AC,
        srs-kg:word-%E4%BD%A0,
        srs-kg:word-%E5%8E%BB,
        srs-kg:word-%E5%8F%AF%E4%BB%A5,
        srs-kg:word-%E6%88%91%E4%BB%AC,
        srs-kg:word-%E8%AF%B4 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-003-Forming%20%27what%20about...%3F%27%20questions%20with%20%27ne%27%20%28%E5%91%A2%29 ;
    srs-kg:pinyin "Nǐ shuō tāmen kěyǐ qù. Wǒmen ne?" ;
    srs-kg:translationEN "You said they can go. What about us?"@en .

srs-inst:sent-gp-a1-005-Showing%20possession%20with%20%27de%27%20%28%E7%9A%84%29-001 a srs-kg:Sentence ;
    rdfs:label "小李 的 手机"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-005-Showing%20possession%20with%20%27de%27%20%28%E7%9A%84%29 ;
    srs-kg:pinyin "Xiǎo Lǐ de shǒujī" ;
    srs-kg:translationEN "Xiao Li's cell phone"@en .

srs-inst:sent-gp-a1-005-Showing%20possession%20with%20%27de%27%20%28%E7%9A%84%29-002 a srs-kg:Sentence ;
    rdfs:label "我 的 手机"@zh ;
    srs-kg:containsWord srs-kg:word-%E6%88%91 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-005-Showing%20possession%20with%20%27de%27%20%28%E7%9A%84%29 ;
    srs-kg:pinyin "Wǒ de shǒujī" ;
    srs-kg:translationEN "My cell phone"@en .

srs-inst:sent-gp-a1-005-Showing%20possession%20with%20%27de%27%20%28%E7%9A%84%29-003 a srs-kg:Sentence ;
    rdfs:label "公司 的 老板"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-005-Showing%20possession%20with%20%27de%27%20%28%E7%9A%84%29 ;
    srs-kg:pinyin "gōngsī de lǎobǎn" ;
    srs-kg:translationEN "the company's boss"@en .

srs-inst:sent-gp-a1-005-Showing%20possession%20with%20%27de%27%20%28%E7%9A%84%29-004 a srs-kg:Sentence ;
    rdfs:label "他 的 小狗"@zh ;
    srs-kg:containsWord srs-kg:word-%E4%BB%96 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-005-Showing%20possession%20with%20%27de%27%20%28%E7%9A%84%29 ;
    srs-kg:pinyin "Tā de xiǎogǒu" ;
    srs-kg:translationEN "His puppy"@en .

srs-inst:sent-gp-a1-006-Expressing%20possession%20with%20%27you%27%20%28%E6%9C%89%29-001 a srs-kg:Sentence ;
    rdfs:label "我 有 钱。"@zh ;
    srs-kg:containsWord srs-kg:word-%E6%88%91 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-006-Expressing%20possession%20with%20%27you%27%20%28%E6%9C%89%29 ;
    srs-kg:pinyin "Wǒ yǒu qián." ;
    srs-kg:translationEN "I have money."@en .

srs-inst:sent-gp-a1-006-Expressing%20possession%20with%20%27you%27%20%28%E6%9C%89%29-002 a srs-kg:Sentence ;
    rdfs:label "他 有 两 个 女儿 。"@zh ;
    srs-kg:containsWord srs-kg:word-%E4%BB%96,
        srs-kg:word-%E5%A5%B3%E5%84%BF,
        srs-kg:word-%E6%9C%89 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-006-Expressing%20possession%20with%20%27you%27%20%28%E6%9C%89%29 ;
    srs-kg:pinyin "Tā yǒu liǎng gè nǚér." ;
    srs-kg:translationEN "He has two daughters."@en .

srs-inst:sent-gp-a1-006-Expressing%20possession%20with%20%27you%27%20%28%E6%9C%89%29-003 a srs-kg:Sentence ;
    rdfs:label "你 有 工作 吗？"@zh ;
    srs-kg:containsWord srs-kg:word-%E4%BD%A0,
        srs-kg:word-%E5%B7%A5%E4%BD%9C,
        srs-kg:word-%E6%9C%89 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-006-Expressing%20possession%20with%20%27you%27%20%28%E6%9C%89%29 ;
    srs-kg:pinyin "Nǐ yǒu gōngzuò ma?" ;
    srs-kg:translationEN "Do you have a job?"@en .

srs-inst:sent-gp-a1-007-Negation%20with%20%27bu%27%20%28%E4%B8%8D%29-001 a srs-kg:Sentence ;
    rdfs:label "她 不 喝 酒。"@zh ;
    srs-kg:containsWord srs-kg:word-%E5%A5%B9 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-007-Negation%20with%20%27bu%27%20%28%E4%B8%8D%29 ;
    srs-kg:pinyin "Tā bù hē jiǔ." ;
    srs-kg:translationEN "She doesn't drink alcohol."@en .

srs-inst:sent-gp-a1-007-Negation%20with%20%27bu%27%20%28%E4%B8%8D%29-002 a srs-kg:Sentence ;
    rdfs:label "我 不 想 工作 。"@zh ;
    srs-kg:containsWord srs-kg:word-%E5%B7%A5%E4%BD%9C,
        srs-kg:word-%E6%88%91 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-007-Negation%20with%20%27bu%27%20%28%E4%B8%8D%29 ;
    srs-kg:pinyin "Wǒ bù xiǎng gōngzuò." ;
    srs-kg:translationEN "I don't want to work."@en .

srs-inst:sent-gp-a1-007-Negation%20with%20%27bu%27%20%28%E4%B8%8D%29-003 a srs-kg:Sentence ;
    rdfs:label "很 多 人 不 喜欢 热狗 。"@zh ;
    srs-kg:containsWord srs-kg:word-%E5%96%9C%E6%AC%A2,
        srs-kg:word-%E7%83%AD%E7%8B%97 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-007-Negation%20with%20%27bu%27%20%28%E4%B8%8D%29 ;
    srs-kg:pinyin "Hěn duō rén bù xǐhuan règǒu." ;
    srs-kg:translationEN "Many people don't like hot dogs."@en .

srs-inst:sent-gp-a1-008-Negating%20%27you%27%20%28%E6%9C%89%29%20with%20%27mei%27%20%28%E6%B2%A1%29-001 a srs-kg:Sentence ;
    rdfs:label "我 没 有 手机 。"@zh ;
    srs-kg:containsWord srs-kg:word-%E6%88%91 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-008-Negating%20%27you%27%20%28%E6%9C%89%29%20with%20%27mei%27%20%28%E6%B2%A1%29 ;
    srs-kg:pinyin "Wǒ méi yǒu shǒujī." ;
    srs-kg:translationEN "I don't have a cell phone."@en .

srs-inst:sent-gp-a1-008-Negating%20%27you%27%20%28%E6%9C%89%29%20with%20%27mei%27%20%28%E6%B2%A1%29-002 a srs-kg:Sentence ;
    rdfs:label "我们 没 有 房子 。"@zh ;
    srs-kg:containsWord srs-kg:word-%E6%88%91%E4%BB%AC,
        srs-kg:word-%E6%88%BF%E5%AD%90 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-008-Negating%20%27you%27%20%28%E6%9C%89%29%20with%20%27mei%27%20%28%E6%B2%A1%29 ;
    srs-kg:pinyin "Wǒmen méi yǒu fángzi." ;
    srs-kg:translationEN "We don't have a house."@en .

srs-inst:sent-gp-a1-008-Negating%20%27you%27%20%28%E6%9C%89%29%20with%20%27mei%27%20%28%E6%B2%A1%29-003 a srs-kg:Sentence ;
    rdfs:label "我们 公司 没 有 电脑 。"@zh ;
    srs-kg:containsWord srs-kg:word-%E6%88%91%E4%BB%AC,
        srs-kg:word-%E7%94%B5%E8%84%91 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-008-Negating%20%27you%27%20%28%E6%9C%89%29%20with%20%27mei%27%20%28%E6%B2%A1%29 ;
    srs-kg:pinyin "Wǒmen gōngsī méi yǒu diànnǎo." ;
    srs-kg:translationEN "Our company doesn't have computers."@en .

srs-inst:sent-gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29-001 a srs-kg:Sentence ;
    rdfs:label "我 也 喜欢。"@zh ;
    srs-kg:containsWord srs-kg:word-%E5%96%9C%E6%AC%A2,
        srs-kg:word-%E6%88%91 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29 ;
    srs-kg:pinyin "Wǒ yě xǐhuan." ;
    srs-kg:translationEN "I also like it."@en .

srs-inst:sent-gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29-002 a srs-kg:Sentence ;
    rdfs:label "我 也 是 学生 。"@zh ;
    srs-kg:containsWord srs-kg:word-%E6%88%91 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29 ;
    srs-kg:pinyin "Wǒ yě shì xuésheng." ;
    srs-kg:translationEN "I am a student too."@en .

srs-inst:sent-gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29-003 a srs-kg:Sentence ;
    rdfs:label "她 也 有 一个 儿子。"@zh ;
    srs-kg:containsWord srs-kg:word-%E5%84%BF%E5%AD%90,
        srs-kg:word-%E5%A5%B9,
        srs-kg:word-%E6%9C%89 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29 ;
    srs-kg:pinyin "Tā yě yǒu yī gè érzi." ;
    srs-kg:translationEN "She also has a son."@en .

srs-inst:sent-gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29-004 a srs-kg:Sentence ;
    rdfs:label "他们 也 是 法国 人 吗？"@zh ;
