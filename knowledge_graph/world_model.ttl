    srs-kg:demonstratesGrammar srs-inst:gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29 ;
    srs-kg:pinyin "Tāmen yě shì Fǎguó rén ma?" ;
    srs-kg:translationEN "Are they also French?"@en .

srs-inst:sent-gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29-005 a srs-kg:Sentence ;
    rdfs:label "我 也 想 学 中文。"@zh ;
    srs-kg:containsWord srs-kg:word-%E6%88%91 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29 ;
    srs-kg:pinyin "Wǒ yě xiǎng xué Zhōngwén." ;
    srs-kg:translationEN "I also want to study Chinese."@en .

srs-inst:sent-gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29-006 a srs-kg:Sentence ;
    rdfs:label "他们 也 会 去吗？"@zh ;
