    srs-kg:demonstratesGrammar srs-inst:gp-a2-070-negative-commands-with-bie ;
    srs-kg:pinyin "Bié hē tài duō." ;
    srs-kg:translationEN "Don't drink too much."@en .

srs-inst:sent-gp-a2-070-negative-commands-with-bie-008 a srs-kg:Sentence ;
