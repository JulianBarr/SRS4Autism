    srs-kg:demonstratesGrammar srs-inst:gp-a1-001-basic-sentence-structure ;
    srs-kg:pinyin "Wǒ qù." ;
    srs-kg:translationEN "I go."@en .

srs-inst:sent-gp-a1-001-basic-sentence-structure-004 a srs-kg:Sentence ;
    rdfs:label "我 吃 肉。"@zh ;
