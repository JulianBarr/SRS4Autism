    srs-kg:translationEN "The weather in Beijing and the weather in Shanghai are not alike."@en .

srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-004 a srs-kg:Sentence ;
    rdfs:label "这个词的意思和那个词一样吗？"@zh ;
