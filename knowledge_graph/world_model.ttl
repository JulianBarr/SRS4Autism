    srs-kg:translationEN "Please write as you read."@en .

srs-inst:sent-gp-a2-071-simultaneous-tasks-with-yibian-007 a srs-kg:Sentence ;
    rdfs:label "不要一边开车，一边打电话。"@zh ;
