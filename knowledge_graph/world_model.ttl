    srs-kg:translationEN "After you get home, call me."@en .

srs-inst:sent-gp-a2-092-After%20a%20specific%20time%20with%20%E4%BB%A5%E5%90%8E%20%28y%C7%90h%C3%B2u%29-010 a srs-kg:Sentence ;
