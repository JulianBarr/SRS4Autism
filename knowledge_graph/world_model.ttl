        srs-inst:sent-gp-a1-009-negation-of-you-with-mei-016 ;
    srs-kg:structure "没 + 有 (+ Obj.)" .

srs-inst:gp-a2-058-approximations-with-chabuduo a srs-kg:GrammarPoint ;
    rdfs:label "Approximations with 'chabuduo'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "差不多 (chàbuduō), translated literally, means \"the difference is not much.\" In practice it means something like \"more or less,\" and is useful for expressing rough approximations. It can be used as a predicate or an adverb. As a predicate, when several things are 差不多, it means they are \"more or less the same.\" As an adverb, place it before the adjective or verb. After 差不多 you can also add a phrase that expresses quantity or time."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-058-approximations-with-chabuduo-001,
        srs-inst:sent-gp-a2-058-approximations-with-chabuduo-002,
        srs-inst:sent-gp-a2-058-approximations-with-chabuduo-003,
        srs-inst:sent-gp-a2-058-approximations-with-chabuduo-004,
        srs-inst:sent-gp-a2-058-approximations-with-chabuduo-005,
        srs-inst:sent-gp-a2-058-approximations-with-chabuduo-006,
        srs-inst:sent-gp-a2-058-approximations-with-chabuduo-007,
        srs-inst:sent-gp-a2-058-approximations-with-chabuduo-008,
        srs-inst:sent-gp-a2-058-approximations-with-chabuduo-009,
