    srs-kg:pinyin "Nǐ zhīdao tā xiànzài duō pàng ma?" ;
    srs-kg:translationEN "Do you know how fat she is now?"@en .

srs-inst:sent-gp-a2-072-asking-about-degree-with-duo-009 a srs-kg:Sentence ;
    rdfs:label "你知道这里的冬天多冷吗？"@zh ;
    srs-kg:containsWord srs-kg:word-%E4%BD%A0,
