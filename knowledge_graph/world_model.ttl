        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-007,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-008,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-009,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-010,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-011,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-012,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-013,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-014,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-015,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-016,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-017,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-018,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-019,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-020 ;
    srs-kg:structure "Positive: 已经 + Verb/Adjective/Time Noun + 了. Negative: 已经 + 不 + Verb Phrase + 了." .

srs-inst:gp-a2-123-multiple-meanings-of-the-auxiliary-verb-yao a srs-kg:GrammarPoint ;
    rdfs:label "Multiple meanings of the auxiliary verb 'yao'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The auxiliary verb 要 (yào) is versatile and can mean 'to want (something)', 'to want to (do something)', 'to need to', or 'to be going to'. The specific meaning is determined by the context of the sentence."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-123-multiple-meanings-of-the-auxiliary-verb-yao-001,
