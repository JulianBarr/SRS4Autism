    srs-kg:pinyin "Wǒ juéde zhè ge cāntīng yě hěn hǎo." ;
    srs-kg:translationEN "I think that this restaurant is also good."@en .

srs-inst:sent-gp-a1-011-the-also-adverb-ye-%E4%B9%9F-025 a srs-kg:Sentence ;
    rdfs:label "A: 我 是 美国人 。 B: 我 也 是 。"@zh ;
