    srs-kg:pinyin "Tā shēngqì le? Wǒ yě hěn shēngqì!" ;
    srs-kg:translationEN "He got angry? I'm also angry!"@en .

srs-inst:sent-gp-a1-011-the-also-adverb-ye-%E4%B9%9F-023 a srs-kg:Sentence ;
    rdfs:label "这 个 问题 也 很 麻烦。"@zh ;
