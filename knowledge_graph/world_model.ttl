    srs-kg:pinyin "Wǒ shēngqì de shíhou qǐng nǐ bùyào xiào." ;
    srs-kg:translationEN "Please don't laugh when I'm angry."@en .

srs-inst:sent-gp-a2-091-When%20with%20%E7%9A%84%E6%97%B6%E5%80%99%20%28de%20sh%C3%ADhou%29-006 a srs-kg:Sentence ;
