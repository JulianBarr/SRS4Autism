srs-inst:sent-gp-a1-003-forming-what-about-questions-with-ne-%E5%91%A2-001 a srs-kg:Sentence ;
    rdfs:label "我 吃 饭 了 。 你 呢？"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-003-forming-what-about-questions-with-ne-%E5%91%A2 ;
    srs-kg:pinyin "Wǒ chī fàn le. Nǐ ne?" ;
    srs-kg:translationEN "I've eaten. What about you?"@en .

srs-inst:sent-gp-a1-003-forming-what-about-questions-with-ne-%E5%91%A2-002 a srs-kg:Sentence ;
    rdfs:label "北京 下 雨 了 。 上海 呢？"@zh ;
