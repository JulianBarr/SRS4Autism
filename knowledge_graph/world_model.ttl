srs-inst:sent-gp-a2-139-using-hao-to-mean-easy-003 a srs-kg:Sentence ;
    rdfs:label "三明治 很 好做 。"@zh ;
    srs-kg:containsWord srs-kg:word-%E5%A5%BD ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-139-using-hao-to-mean-easy ;
    srs-kg:pinyin "Sānmíngzhì hěn hǎozuò ." ;
    srs-kg:translationEN "Sandwiches are easy to make."@en .

srs-inst:sent-gp-a2-139-using-hao-to-mean-easy-004 a srs-kg:Sentence ;
    rdfs:label "苹果 手机 现在 很 好买 。"@zh ;
    srs-kg:containsWord srs-kg:word-%E4%B9%B0,
        srs-kg:word-%E5%A5%BD,
        srs-kg:word-%E7%8E%B0%E5%9C%A8,
        srs-kg:word-%E8%8B%B9%E6%9E%9C ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-139-using-hao-to-mean-easy ;
    srs-kg:pinyin "Píngguǒ shǒujī xiànzài hěn hǎomǎi ." ;
    srs-kg:translationEN "iPhones are easy to buy now."@en .

srs-inst:sent-gp-a2-139-using-hao-to-mean-easy-005 a srs-kg:Sentence ;
    rdfs:label "这 个 笔 很 好用 。"@zh ;
    srs-kg:containsWord srs-kg:word-%E5%A5%BD,
        srs-kg:word-%E8%BF%99%E4%B8%AA ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-139-using-hao-to-mean-easy ;
    srs-kg:pinyin "Zhè ge bǐ hěn hǎoyòng ." ;
    srs-kg:translationEN "This pen is easy to use."@en .

srs-inst:sent-gp-a2-139-using-hao-to-mean-easy-006 a srs-kg:Sentence ;
    rdfs:label "这 首 歌 很 好听 。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-139-using-hao-to-mean-easy ;
    srs-kg:pinyin "Zhè shǒu gē hěn hǎotīng ." ;
    srs-kg:translationEN "This song is good to listen to."@en .

srs-inst:sent-gp-not-mentioned-059-expressing-approximation-with-chabuduo-001 a srs-kg:Sentence ;
    rdfs:label "我 在 这 家 公司 工作 了 差不多 十 年 了。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-not-mentioned-059-expressing-approximation-with-chabuduo ;
    srs-kg:pinyin "Wǒ zài zhè jiā gōngsī gōngzuò le chàbuduō shí nián le." ;
    srs-kg:translationEN "I've worked for this company for almost ten years."@en .

srs-inst:sent-gp-not-mentioned-059-expressing-approximation-with-chabuduo-002 a srs-kg:Sentence ;
    rdfs:label "我父母 结婚 差不多 二十 年 了。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-not-mentioned-059-expressing-approximation-with-chabuduo ;
    srs-kg:pinyin "Wǒfùmǔ jiéhūn chàbuduō èrshí nián le." ;
    srs-kg:translationEN "My parents have been married for about twenty years."@en .

srs-inst:sent-gp-not-mentioned-059-expressing-approximation-with-chabuduo-003 a srs-kg:Sentence ;
    rdfs:label "差不多 两 个 星期 以前，我 在 北京 见 过 他。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-not-mentioned-059-expressing-approximation-with-chabuduo ;
    srs-kg:pinyin "chàbuduō liǎng gè xīngqí yǐqián, wǒ zài Běijīng jiàn guo tā." ;
    srs-kg:translationEN "About two weeks ago I met with him in Beijing."@en .

srs-inst:sent-gp-not-specified-066-emphasizing-comparisons-with-geng-001 a srs-kg:Sentence ;
    rdfs:label "春节比中秋节更热闹。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-not-specified-066-emphasizing-comparisons-with-geng ;
    srs-kg:pinyin "Chūnjié bǐ Zhōngqiūjié gèng rènao." ;
    srs-kg:translationEN "Spring Festival is even more boisterous than Mid-autumn Festival."@en .

srs-inst:sent-gp-not-specified-066-emphasizing-comparisons-with-geng-002 a srs-kg:Sentence ;
    rdfs:label "汉字比声调更难。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-not-specified-066-emphasizing-comparisons-with-geng ;
    srs-kg:pinyin "Hànzì bǐ shēngdiào gèng nán." ;
    srs-kg:translationEN "Chinese characters are even more difficult than tones."@en .

srs-inst:sent-gp-not-specified-066-emphasizing-comparisons-with-geng-003 a srs-kg:Sentence ;
    rdfs:label "他现在的女朋友比以前的更漂亮。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-not-specified-066-emphasizing-comparisons-with-geng ;
    srs-kg:pinyin "Tā xiànzài de nǚpéngyou bǐ yǐqián de gèng piàoliang." ;
    srs-kg:translationEN "His current girlfriend is even more beautiful than his previous one."@en .

srs-inst:sent-gp-not-specified-066-emphasizing-comparisons-with-geng-004 a srs-kg:Sentence ;
    rdfs:label "中国的高铁比飞机更方便。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-not-specified-066-emphasizing-comparisons-with-geng ;
    srs-kg:pinyin "Zhōngguó de gāotiě bǐ fēijī gèng fāngbiàn." ;
    srs-kg:translationEN "China's high-speed trains are even more convenient than airplanes."@en .

srs-inst:sent-gp-not-specified-119-comparisons-with-bi-and-geng-001 a srs-kg:Sentence ;
    rdfs:label "小李 比 小张 更 高 。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-not-specified-119-comparisons-with-bi-and-geng ;
    srs-kg:pinyin "Xiǎo Lǐ bǐ Xiǎo Zhāng gèng gāo ." ;
    srs-kg:translationEN "Xiao Li is even taller than Xiao Zhang."@en .

srs-inst:sent-gp-not-specified-119-comparisons-with-bi-and-geng-002 a srs-kg:Sentence ;
    rdfs:label "我 哥哥 比 我 更 高 。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-not-specified-119-comparisons-with-bi-and-geng ;
    srs-kg:pinyin "Wǒ gēge bǐ wǒ gèng gāo ." ;
    srs-kg:translationEN "My big brother is even taller than me."@en .

srs-inst:sent-gp-not-specified-119-comparisons-with-bi-and-geng-003 a srs-kg:Sentence ;
    rdfs:label "你男朋友 比 我男朋友 更 帅 。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-not-specified-119-comparisons-with-bi-and-geng ;
    srs-kg:pinyin "Nǐ nánpéngyou bǐ wǒ nánpéngyou gèng shuài ." ;
    srs-kg:translationEN "Your boyfriend is even more handsome than mine."@en .

srs-inst:sent-gp-not-specified-119-comparisons-with-bi-and-geng-004 a srs-kg:Sentence ;
    rdfs:label "这里 的 冬天 比 纽约 的 冬天 更 冷 。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-not-specified-119-comparisons-with-bi-and-geng ;
    srs-kg:pinyin "Zhèlǐ de dōngtiān bǐ Niǔyuē de dōngtiān gèng lěng ." ;
    srs-kg:translationEN "The winter here is even colder than it is in New York."@en .

srs-inst:sent-gp-not-specified-119-comparisons-with-bi-and-geng-005 a srs-kg:Sentence ;
    rdfs:label "中文 语法 比 汉字 更 难 。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-not-specified-119-comparisons-with-bi-and-geng ;
    srs-kg:pinyin "Zhōngwén yǔfǎ bǐ hànzì gèng nán ." ;
    srs-kg:translationEN "Chinese grammar is even more difficult than Chinese characters."@en .

srs-inst:sent-gp-not-specified-119-comparisons-with-bi-and-geng-006 a srs-kg:Sentence ;
    rdfs:label "你的 问题 比 我的 问题 更 麻烦 。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-not-specified-119-comparisons-with-bi-and-geng ;
    srs-kg:pinyin "Nǐ de wènti bǐ wǒ de wènti gèng máfan ." ;
    srs-kg:translationEN "Your problem is even more troublesome than mine."@en .

srs-kg:concept-friend a srs-kg:Concept ;
    rdfs:label "concept:friend" ;
    rdfs:comment "A person you know well and regard with affection and trust." .

srs-kg:grammar-de a srs-kg:GrammarPoint ;
    rdfs:label "Using '的' (de)" ;
    srs-kg:hskLevel 1 ;
    srs-kg:structure "Noun + 的 + Noun" .

srs-inst:gp-a2-083-using-zui-to-express-favorite a srs-kg:GrammarPoint ;
    rdfs:label "Using \"zui\" to express \"favorite\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "Pairing 最 (zuì) with a psychological verb like 喜欢 (xǐhuan) is a common way to talk about one's 'favorite'. It can be used with other verbs and adjectives to express the superlative degree, meaning 'the most'."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-083-using-zui-to-express-favorite-001,
        srs-inst:sent-gp-a2-083-using-zui-to-express-favorite-002 ;
    srs-kg:structure "Subj. + 最 + Verb/Adj. (+ Obj.)" .

srs-kg:char-peng a srs-kg:Character ;
    rdfs:label "朋" ;
    srs-kg:definition "friend, pal" ;
    srs-kg:glyph "朋" ;
    srs-kg:pinyin "péng" .

srs-kg:char-you a srs-kg:Character ;
    rdfs:label "友" ;
    srs-kg:definition "friend, companion" ;
    srs-kg:glyph "友" ;
    srs-kg:pinyin "yǒu" .

srs-inst:gp-a1-002-forming-questions-with-ma-%E5%90%97 a srs-kg:GrammarPoint ;
    rdfs:label "Forming questions with 'ma' (吗)"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "Simple statements can be turned into yes/no questions by adding the particle 吗 (ma) to the end of the sentence."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-002-forming-questions-with-ma-%E5%90%97-001,
        srs-inst:sent-gp-a1-002-forming-questions-with-ma-%E5%90%97-002,
        srs-inst:sent-gp-a1-002-forming-questions-with-ma-%E5%90%97-003 ;
    srs-kg:structure "Statement + 吗 (ma)?" .

srs-inst:gp-a1-003-forming-what-about-questions-with-ne-%E5%91%A2 a srs-kg:GrammarPoint ;
    rdfs:label "Forming 'what about...?' questions with 'ne' (呢)"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The particle 呢 (ne) is added after a topic or subject to ask 'what about...?' or 'how about...?'."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-003-forming-what-about-questions-with-ne-%E5%91%A2-001,
        srs-inst:sent-gp-a1-003-forming-what-about-questions-with-ne-%E5%91%A2-002,
        srs-inst:sent-gp-a1-003-forming-what-about-questions-with-ne-%E5%91%A2-003 ;
    srs-kg:structure "Topic/Subject + 呢 (ne)?" .

srs-inst:gp-a1-004-using-question-words a srs-kg:GrammarPoint ;
    rdfs:label "Using Question Words"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "Questions with question words (like who, what, where) follow the same word order as a statement. The question word is placed in the position of the information being sought, typically at the end of the sentence in the object position."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-004-using-question-words-002,
        srs-inst:sent-gp-a1-004-using-question-words-004,
        srs-inst:sent-gp-a1-004-using-question-words-005 ;
    srs-kg:structure "Subject + Verb + Question Word" .

srs-inst:gp-a1-006-expressing-possession-with-you-%E6%9C%89 a srs-kg:GrammarPoint ;
    rdfs:label "Expressing possession with 'you' (有)"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The verb 有 (yǒu) means 'to have' and is used to indicate that someone or something possesses an object."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-006-expressing-possession-with-you-%E6%9C%89-001,
        srs-inst:sent-gp-a1-006-expressing-possession-with-you-%E6%9C%89-002,
        srs-inst:sent-gp-a1-006-expressing-possession-with-you-%E6%9C%89-003 ;
    srs-kg:structure "Subject + 有 (yǒu) + Object" .

srs-inst:gp-a1-007-negation-with-bu-%E4%B8%8D a srs-kg:GrammarPoint ;
    rdfs:label "Negation with 'bu' (不)"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The word 不 (bù) is used to negate verbs and adjectives, functioning much like the word 'not' in English. It is placed directly before the word it negates."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-007-negation-with-bu-%E4%B8%8D-001,
        srs-inst:sent-gp-a1-007-negation-with-bu-%E4%B8%8D-002,
        srs-inst:sent-gp-a1-007-negation-with-bu-%E4%B8%8D-003 ;
    srs-kg:structure "Subject + 不 (bù) + Verb / Adjective" .

srs-inst:gp-a1-008-negating-you-%E6%9C%89-with-mei-%E6%B2%A1 a srs-kg:GrammarPoint ;
    rdfs:label "Negating 'you' (有) with 'mei' (没)"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "To negate the verb 有 (yǒu), meaning 'to have', the particle 没 (méi) is used instead of 不 (bù). It is placed before 有 (yǒu) to form 没有 (méiyǒu), which means 'do not have'."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-008-negating-you-%E6%9C%89-with-mei-%E6%B2%A1-001,
        srs-inst:sent-gp-a1-008-negating-you-%E6%9C%89-with-mei-%E6%B2%A1-002,
        srs-inst:sent-gp-a1-008-negating-you-%E6%9C%89-with-mei-%E6%B2%A1-003 ;
    srs-kg:structure "Subject + 没有 (méiyǒu) + Object" .

srs-inst:gp-a1-028-asking-where-is-with-ne a srs-kg:GrammarPoint ;
    rdfs:label "Asking 'where is...?' with 'ne'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "When used on its own after a noun, 呢 (ne) can be a question asking for the location of that person or thing. The context should make it clear what is being asked."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-028-asking-where-is-with-ne-001,
        srs-inst:sent-gp-a1-028-asking-where-is-with-ne-002,
        srs-inst:sent-gp-a1-028-asking-where-is-with-ne-003 ;
    srs-kg:structure "[Missing Person/Thing] + 呢？" .

srs-inst:gp-not-mentioned-059-expressing-approximation-with-chabuduo a srs-kg:GrammarPoint ;
    rdfs:label "Expressing approximation with 'chabuduo'"@en ;
    srs-kg:cefrLevel "Not mentioned" ;
    srs-kg:explanation "Used before a number, quantity, or time phrase to express approximation, similar to 'almost' or 'about' in English."@en ;
    srs-kg:hasExample srs-inst:sent-gp-not-mentioned-059-expressing-approximation-with-chabuduo-001,
        srs-inst:sent-gp-not-mentioned-059-expressing-approximation-with-chabuduo-002,
        srs-inst:sent-gp-not-mentioned-059-expressing-approximation-with-chabuduo-003 ;
    srs-kg:structure "差不多 + Quantity/Time Phrase" .

srs-inst:gp-a1-005-showing-possession-with-de-%E7%9A%84 a srs-kg:GrammarPoint ;
    rdfs:label "Showing possession with 'de' (的)"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The particle 的 (de) is used to show possession, similar to an apostrophe 's' in English. It is placed after the 'owner' and before the 'thing owned'."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-005-showing-possession-with-de-%E7%9A%84-001,
        srs-inst:sent-gp-a1-005-showing-possession-with-de-%E7%9A%84-002,
        srs-inst:sent-gp-a1-005-showing-possession-with-de-%E7%9A%84-003,
        srs-inst:sent-gp-a1-005-showing-possession-with-de-%E7%9A%84-004 ;
    srs-kg:structure "Owner + 的 (de) + Thing Owned" .

srs-inst:gp-a1-017-structure-of-days-of-the-week a srs-kg:GrammarPoint ;
    rdfs:label "Structure of days of the week"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "Days of the week are formed using 星期 (xīngqī) followed by a number. Monday is 星期一 (xīngqīyī), Tuesday is 星期二 (xīngqī'èr), and so on up to Saturday (星期六). Sunday is the exception, referred to as 星期天 (xīngqītiān) or, more formally, 星期日 (xīngqīrì). The week is considered to start on Monday."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-017-structure-of-days-of-the-week-001,
        srs-inst:sent-gp-a1-017-structure-of-days-of-the-week-002,
        srs-inst:sent-gp-a1-017-structure-of-days-of-the-week-003,
        srs-inst:sent-gp-a1-017-structure-of-days-of-the-week-004 ;
    srs-kg:structure "星期 + Number (1-6) / 星期天 / 星期日" .

srs-inst:gp-a1-039-expressing-permission-with-keyi a srs-kg:GrammarPoint ;
    rdfs:label "Expressing permission with \"keyi\""@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "可以 (kěyǐ) is an auxiliary verb primarily used for expressing permission. It's often translated as \"can,\" but in order to not get it confused with other words, it's best to think of it as \"may\" to emphasize the permission aspect. Just put 可以 (kěyǐ) in directly before a verb to create a meaning of \"may\" (plus the verb). It's the same structure whether it's a statement or a question."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-039-expressing-permission-with-keyi-001,
        srs-inst:sent-gp-a1-039-expressing-permission-with-keyi-002,
        srs-inst:sent-gp-a1-039-expressing-permission-with-keyi-003,
        srs-inst:sent-gp-a1-039-expressing-permission-with-keyi-004 ;
    srs-kg:structure "Subj. + 可以 + Verb + Obj." .

srs-inst:gp-a1-048-expressing-excessively-with-tai a srs-kg:GrammarPoint ;
    rdfs:label "Expressing 'excessively' with 'tai'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "To express that something is 'too' or 'excessively' a certain quality, use the adverb 太 (tài) before an adjective, followed by the particle 了 (le) at the end of the phrase. This structure can be used to make a complaint or state a reason, but can also be used colloquially to mean 'so' or 'very'."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-048-expressing-excessively-with-tai-001,
        srs-inst:sent-gp-a1-048-expressing-excessively-with-tai-002,
        srs-inst:sent-gp-a1-048-expressing-excessively-with-tai-003,
        srs-inst:sent-gp-a1-048-expressing-excessively-with-tai-004 ;
    srs-kg:structure "太 + Adj. + 了" .

srs-inst:gp-not-specified-066-emphasizing-comparisons-with-geng a srs-kg:GrammarPoint ;
    rdfs:label "Emphasizing comparisons with 'geng'"@en ;
    srs-kg:cefrLevel "Not specified" ;
    srs-kg:explanation "This structure uses '更' (gèng) in combination with '比' (bǐ) to make a comparison and emphasize that the difference is significant, translating to 'even more... than...'."@en ;
    srs-kg:hasExample srs-inst:sent-gp-not-specified-066-emphasizing-comparisons-with-geng-001,
        srs-inst:sent-gp-not-specified-066-emphasizing-comparisons-with-geng-002,
        srs-inst:sent-gp-not-specified-066-emphasizing-comparisons-with-geng-003,
        srs-inst:sent-gp-not-specified-066-emphasizing-comparisons-with-geng-004 ;
    srs-kg:structure "Noun 1 + 比 + Noun 2 + 更 + Adj." .

srs-inst:gp-a1-024-expressing-half-hours a srs-kg:GrammarPoint ;
    rdfs:label "Expressing half hours"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "To say 'half past' an hour, add 半 (bàn) after the hour and 点 (diăn)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-024-expressing-half-hours-001,
        srs-inst:sent-gp-a1-024-expressing-half-hours-002,
        srs-inst:sent-gp-a1-024-expressing-half-hours-003,
        srs-inst:sent-gp-a1-024-expressing-half-hours-004,
        srs-inst:sent-gp-a1-024-expressing-half-hours-005 ;
    srs-kg:structure "x 点 + 半" .

srs-inst:gp-a1-040-negating-%E5%8F%AF%E4%BB%A5-sentences a srs-kg:GrammarPoint ;
    rdfs:label "Negating 可以 sentences"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "To negate sentences with the modal verb 可以 (kěyǐ), which means 'can' or 'may', insert the negative particle 不 (bù) directly before 可以 (kěyǐ). This structure is used to express that something is not allowed or not permitted."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-040-negating-%E5%8F%AF%E4%BB%A5-sentences-001,
        srs-inst:sent-gp-a1-040-negating-%E5%8F%AF%E4%BB%A5-sentences-002,
        srs-inst:sent-gp-a1-040-negating-%E5%8F%AF%E4%BB%A5-sentences-003,
        srs-inst:sent-gp-a1-040-negating-%E5%8F%AF%E4%BB%A5-sentences-004,
        srs-inst:sent-gp-a1-040-negating-%E5%8F%AF%E4%BB%A5-sentences-005 ;
    srs-kg:structure "Subj. + 不 + 可以 + Verb + Obj." .

srs-inst:gp-a1-098-using-%E9%9B%B6-l%C3%ADng-for-minutes-under-10 a srs-kg:GrammarPoint ;
    rdfs:label "Using 零 (líng) for minutes under 10"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "In Chinese, when the minute is under 10, the word 零 (líng) is often used after 点 (diǎn). For example, 2:07 would be said as “两点零七分” (liǎng diǎn líng qī fēn). However, note that when speaking, it is very common for most Chinese people take out the “分 (fēn)” at the end of the time."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-098-using-%E9%9B%B6-l%C3%ADng-for-minutes-under-10-001,
        srs-inst:sent-gp-a1-098-using-%E9%9B%B6-l%C3%ADng-for-minutes-under-10-002,
        srs-inst:sent-gp-a1-098-using-%E9%9B%B6-l%C3%ADng-for-minutes-under-10-003,
        srs-inst:sent-gp-a1-098-using-%E9%9B%B6-l%C3%ADng-for-minutes-under-10-004,
        srs-inst:sent-gp-a1-098-using-%E9%9B%B6-l%C3%ADng-for-minutes-under-10-005 ;
    srs-kg:structure "x 点 零 y 分" .

srs-inst:gp-a1-099-expressing-quarter-hours-with-%E5%88%BB-k%C3%A8 a srs-kg:GrammarPoint ;
    rdfs:label "Expressing quarter hours with 刻 (kè)"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "In Chinese, quarter hours are expressed for x:15 (一刻) and x:45 (三刻). The word 刻 (kè) for 'quarter hour' comes after 点 (diǎn). You can also use 十五分 (shíwǔ fēn) for '15 minutes' or 四十五分 (sìshíwǔ fēn) for '45 minutes'."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-099-expressing-quarter-hours-with-%E5%88%BB-k%C3%A8-001,
        srs-inst:sent-gp-a1-099-expressing-quarter-hours-with-%E5%88%BB-k%C3%A8-002,
        srs-inst:sent-gp-a1-099-expressing-quarter-hours-with-%E5%88%BB-k%C3%A8-003,
        srs-inst:sent-gp-a1-099-expressing-quarter-hours-with-%E5%88%BB-k%C3%A8-004,
        srs-inst:sent-gp-a1-099-expressing-quarter-hours-with-%E5%88%BB-k%C3%A8-005 ;
    srs-kg:structure "x 点 y 刻" .

srs-inst:gp-a2-100-expressing-minutes-to-the-hour-with-%E5%B7%AE-ch%C4%81 a srs-kg:GrammarPoint ;
    rdfs:label "Expressing minutes to the hour with 差 (chā)"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "When expressing how many minutes it will be until the next full hour, you put 差 (chā) in front of the time expression."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-100-expressing-minutes-to-the-hour-with-%E5%B7%AE-ch%C4%81-001,
        srs-inst:sent-gp-a2-100-expressing-minutes-to-the-hour-with-%E5%B7%AE-ch%C4%81-002,
        srs-inst:sent-gp-a2-100-expressing-minutes-to-the-hour-with-%E5%B7%AE-ch%C4%81-003,
        srs-inst:sent-gp-a2-100-expressing-minutes-to-the-hour-with-%E5%B7%AE-ch%C4%81-004,
        srs-inst:sent-gp-a2-100-expressing-minutes-to-the-hour-with-%E5%B7%AE-ch%C4%81-005 ;
    srs-kg:structure "差 + minutes + 分 + hour + 点" .

srs-inst:gp-a2-101-using-ji-to-mean-several a srs-kg:GrammarPoint ;
    rdfs:label "Using \"ji\" to mean \"several\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "One of the definitions of the common character 几 (jǐ) is 'several,' 'a couple' or 'a few.' It's an uncertain number that is at least more than one, but less than ten. The simplest way to use 几 (jǐ) is to use it directly with a measure word. It means 'a few,' less than ten or so, things."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-101-using-ji-to-mean-several-001,
        srs-inst:sent-gp-a2-101-using-ji-to-mean-several-002,
        srs-inst:sent-gp-a2-101-using-ji-to-mean-several-003,
        srs-inst:sent-gp-a2-101-using-ji-to-mean-several-004,
        srs-inst:sent-gp-a2-101-using-ji-to-mean-several-005 ;
    srs-kg:structure "几 + Measure Word + Noun" .

srs-inst:gp-a2-102-using-ji-shi-for-a-few-tens a srs-kg:GrammarPoint ;
    rdfs:label "Using \"ji shi\" for \"a few tens\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "It is similar to how in English we can say, 'a few dozen' or 'a couple dozen,' though in this case instead of 'twelves of something' we are saying 'tens of something.'"@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-102-using-ji-shi-for-a-few-tens-001,
        srs-inst:sent-gp-a2-102-using-ji-shi-for-a-few-tens-002,
        srs-inst:sent-gp-a2-102-using-ji-shi-for-a-few-tens-003,
        srs-inst:sent-gp-a2-102-using-ji-shi-for-a-few-tens-004,
        srs-inst:sent-gp-a2-102-using-ji-shi-for-a-few-tens-005 ;
    srs-kg:structure "几 + 十 + Measure Word + Noun" .

srs-inst:gp-a2-103-using-ji-with-larger-numbers a srs-kg:GrammarPoint ;
    rdfs:label "Using \"ji\" with larger numbers"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "In Chinese we can put 几 (jǐ) together with 百 (bǎi), 千 (qiān), or 万 (wàn), just like how in English we might say, 'a few hundred' or a 'few thousand.'"@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-103-using-ji-with-larger-numbers-001,
        srs-inst:sent-gp-a2-103-using-ji-with-larger-numbers-002,
        srs-inst:sent-gp-a2-103-using-ji-with-larger-numbers-003,
        srs-inst:sent-gp-a2-103-using-ji-with-larger-numbers-004,
        srs-inst:sent-gp-a2-103-using-ji-with-larger-numbers-005 ;
    srs-kg:structure "几 + 百/千/万 + Measure Word + Noun" .

srs-inst:gp-a2-105-conceding-with-ba a srs-kg:GrammarPoint ;
    rdfs:label "Conceding with \"ba\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The particle 吧 (ba) can be used to concede a point. That is, 吧 (ba) can be used to accept or agree with something that you're not particularly happy about, the way we might use 'all right' or 'fine then' in English. This usage is placed on the end of a sentence or statement."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-105-conceding-with-ba-001,
        srs-inst:sent-gp-a2-105-conceding-with-ba-002,
        srs-inst:sent-gp-a2-105-conceding-with-ba-003,
        srs-inst:sent-gp-a2-105-conceding-with-ba-004,
        srs-inst:sent-gp-a2-105-conceding-with-ba-005 ;
    srs-kg:structure "Statement + 吧" .

srs-inst:gp-a2-106-expressing-already-with-just-le a srs-kg:GrammarPoint ;
    rdfs:label "Expressing \"already\" with just \"le\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "While 已经 (yǐjīng) means 'already' and is used with 了 (le), the feeling of 'already' can also be expressed with 了 (le) alone, typically in response to a preceding question or statement."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-106-expressing-already-with-just-le-001,
        srs-inst:sent-gp-a2-106-expressing-already-with-just-le-002,
        srs-inst:sent-gp-a2-106-expressing-already-with-just-le-003,
        srs-inst:sent-gp-a2-106-expressing-already-with-just-le-004,
        srs-inst:sent-gp-a2-106-expressing-already-with-just-le-005 ;
    srs-kg:structure "[Verb phrase] + 了" .

srs-inst:gp-a2-110-expressing-experiences-with-guo a srs-kg:GrammarPoint ;
    rdfs:label "Expressing experiences with 'guo'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The aspect particle 过 (guò) is used to indicate that an action has been experienced in the past. What this expresses is that the verb has been done at least once before, without specifying a particular time. 过 (guò) is used to talk about whether something has ever happened - whether it has been experienced."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-110-expressing-experiences-with-guo-001,
        srs-inst:sent-gp-a2-110-expressing-experiences-with-guo-002,
        srs-inst:sent-gp-a2-110-expressing-experiences-with-guo-003,
        srs-inst:sent-gp-a2-110-expressing-experiences-with-guo-004,
        srs-inst:sent-gp-a2-110-expressing-experiences-with-guo-005 ;
    srs-kg:structure "Subj. + Verb + 过 + Obj." .

srs-inst:gp-a2-111-negating-experiences-with-guo a srs-kg:GrammarPoint ;
    rdfs:label "Negating experiences with 'guo'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "Because 过 (guò) is used to talk about past actions, it should be negated with 没 (méi). This indicates that someone lacks the experience of having done something, and is often translated as 'have never' done something."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-111-negating-experiences-with-guo-001,
        srs-inst:sent-gp-a2-111-negating-experiences-with-guo-002,
        srs-inst:sent-gp-a2-111-negating-experiences-with-guo-003,
        srs-inst:sent-gp-a2-111-negating-experiences-with-guo-004,
        srs-inst:sent-gp-a2-111-negating-experiences-with-guo-005 ;
    srs-kg:structure "Subj. + 没 + Verb + 过 + Obj." .

srs-inst:gp-a2-115-structural-particle-%E5%BE%97-de-after-verbs a srs-kg:GrammarPoint ;
    rdfs:label "Structural particle 得 (de) after verbs"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "This form of 'de' is used to construct various kinds of complements and is usually associated with verbs. It describes the manner or result of an action."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-115-structural-particle-%E5%BE%97-de-after-verbs-001,
        srs-inst:sent-gp-a2-115-structural-particle-%E5%BE%97-de-after-verbs-002,
        srs-inst:sent-gp-a2-115-structural-particle-%E5%BE%97-de-after-verbs-003,
        srs-inst:sent-gp-a2-115-structural-particle-%E5%BE%97-de-after-verbs-004,
        srs-inst:sent-gp-a2-115-structural-particle-%E5%BE%97-de-after-verbs-005 ;
    srs-kg:structure "Verb + 得 + Complement" .

srs-inst:gp-a2-116-structural-particle-%E5%9C%B0-de-before-verbs a srs-kg:GrammarPoint ;
    rdfs:label "Structural particle 地 (de) before verbs"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "This form of 'de' is used to turn adjectives into adverbs, and can be thought of as equivalent to the suffix '-ly' in English. The 'Adj. + 地' phrase (an adverbial) modifies the verb that follows it."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-116-structural-particle-%E5%9C%B0-de-before-verbs-001,
        srs-inst:sent-gp-a2-116-structural-particle-%E5%9C%B0-de-before-verbs-002,
        srs-inst:sent-gp-a2-116-structural-particle-%E5%9C%B0-de-before-verbs-003,
        srs-inst:sent-gp-a2-116-structural-particle-%E5%9C%B0-de-before-verbs-004,
        srs-inst:sent-gp-a2-116-structural-particle-%E5%9C%B0-de-before-verbs-005 ;
    srs-kg:structure "Adj. + 地 + Verb" .

srs-inst:gp-a2-125-expressing-will-with-hui a srs-kg:GrammarPoint ;
    rdfs:label "Expressing 'will' with 'hui'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "会 (huì) can be used to indicate that something will happen in the future or that someone will do something. The negative form is 不会 (bù huì)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-125-expressing-will-with-hui-001,
        srs-inst:sent-gp-a2-125-expressing-will-with-hui-002,
        srs-inst:sent-gp-a2-125-expressing-will-with-hui-003,
        srs-inst:sent-gp-a2-125-expressing-will-with-hui-004,
        srs-inst:sent-gp-a2-125-expressing-will-with-hui-005 ;
    srs-kg:structure "Subj. + (不)会 + Verb + Obj." .

srs-inst:gp-a1-001-basic-sentence-structure a srs-kg:GrammarPoint ;
    rdfs:label "Basic Sentence Structure"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The basic sentence structure in Chinese is often the same as in English, following a Subject-Verb-Object (SVO) pattern for simple sentences."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-001-basic-sentence-structure-001,
        srs-inst:sent-gp-a1-001-basic-sentence-structure-002,
        srs-inst:sent-gp-a1-001-basic-sentence-structure-003,
        srs-inst:sent-gp-a1-001-basic-sentence-structure-004,
        srs-inst:sent-gp-a1-001-basic-sentence-structure-005,
        srs-inst:sent-gp-a1-001-basic-sentence-structure-006 ;
    srs-kg:structure "Subject + Verb (+ Object)" .

srs-inst:gp-a1-014-age-with-sui-%E5%B2%81 a srs-kg:GrammarPoint ;
    rdfs:label "Age with 'sui' (岁)"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "To state someone's age in Chinese, use 岁 (suì). The structure is simply 'Subject + Number + 岁'. Unlike in English, you do not need to include a verb like 是 (shì), nor should you use a measure word like 个 (gè)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-014-age-with-sui-%E5%B2%81-001,
        srs-inst:sent-gp-a1-014-age-with-sui-%E5%B2%81-002,
        srs-inst:sent-gp-a1-014-age-with-sui-%E5%B2%81-003,
        srs-inst:sent-gp-a1-014-age-with-sui-%E5%B2%81-004,
        srs-inst:sent-gp-a1-014-age-with-sui-%E5%B2%81-005,
        srs-inst:sent-gp-a1-014-age-with-sui-%E5%B2%81-006 ;
    srs-kg:structure "Subj. + Number + 岁" .

srs-inst:gp-a1-019-expressing-numbers-20-99-tens a srs-kg:GrammarPoint ;
    rdfs:label "Expressing numbers 20-99 (Tens)"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "Tens (20, 30, etc.) are formed by a digit (2-9) followed by 十 (shí). For numbers with a unit digit (e.g., 23), the unit is simply added at the end."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-019-expressing-numbers-20-99-tens-002,
        srs-inst:sent-gp-a1-019-expressing-numbers-20-99-tens-004,
        srs-inst:sent-gp-a1-019-expressing-numbers-20-99-tens-006,
        srs-inst:sent-gp-a1-019-expressing-numbers-20-99-tens-008,
        srs-inst:sent-gp-a1-019-expressing-numbers-20-99-tens-009,
        srs-inst:sent-gp-a1-019-expressing-numbers-20-99-tens-010 ;
    srs-kg:structure "x + 十 + y" .

srs-inst:gp-a1-023-expressing-time-on-the-hour a srs-kg:GrammarPoint ;
    rdfs:label "Expressing time on the hour"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "Express the time on the hour with a number (1-12) followed by 点 (diăn), meaning 'o'clock'. When needed, specify a.m. with 上午 (shàngwǔ) or p.m. with 下午 (xiàwǔ) before the time. Note that 'two o'clock' is 两点 (liǎng diǎn)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-023-expressing-time-on-the-hour-002,
        srs-inst:sent-gp-a1-023-expressing-time-on-the-hour-003,
        srs-inst:sent-gp-a1-023-expressing-time-on-the-hour-004,
        srs-inst:sent-gp-a1-023-expressing-time-on-the-hour-005,
        srs-inst:sent-gp-a1-023-expressing-time-on-the-hour-006,
        srs-inst:sent-gp-a1-023-expressing-time-on-the-hour-007 ;
    srs-kg:structure "(Time of day +) x 点" .

srs-inst:gp-a1-049-expressing-too-with-taile a srs-kg:GrammarPoint ;
    rdfs:label "Expressing \"too\" with \"tai...le\""@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "This pattern is used to express \"too\" or \"so\" with an adjective. It can be used for complaints, like something being 'too dirty', or for exclamations and praise, like something being 'so great'. The pattern can also be used with modal verbs and psychological verbs to intensify the degree."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-049-expressing-too-with-taile-001,
        srs-inst:sent-gp-a1-049-expressing-too-with-taile-002,
        srs-inst:sent-gp-a1-049-expressing-too-with-taile-003,
        srs-inst:sent-gp-a1-049-expressing-too-with-taile-004,
        srs-inst:sent-gp-a1-049-expressing-too-with-taile-005,
        srs-inst:sent-gp-a1-049-expressing-too-with-taile-006 ;
    srs-kg:structure "太 + Adj. + 了" .

srs-inst:gp-a2-065-expressing-even-more-with-geng a srs-kg:GrammarPoint ;
    rdfs:label "Expressing 'even more' with 'geng'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "更 (gèng) is used to express 'even more' and generally comes before adjectives. It's not just a way to make a comparative, but rather to add 'even more' to an already existing quality. It can be used with 比 (bǐ) to express that 'A is even more Adj. than B.'"@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-065-expressing-even-more-with-geng-001,
        srs-inst:sent-gp-a2-065-expressing-even-more-with-geng-002,
        srs-inst:sent-gp-a2-065-expressing-even-more-with-geng-003,
        srs-inst:sent-gp-a2-065-expressing-even-more-with-geng-004,
        srs-inst:sent-gp-a2-065-expressing-even-more-with-geng-005,
        srs-inst:sent-gp-a2-065-expressing-even-more-with-geng-006 ;
    srs-kg:structure "更 + Adj. OR A + 比 + B + 更 + Adj." .

srs-inst:gp-a2-139-using-hao-to-mean-easy a srs-kg:GrammarPoint ;
    rdfs:label "Using 'hao' to mean 'easy'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "好 (hǎo) can be placed before a verb to express that something is 'easy to do' or 'good to do.' With most verbs, it means 'easy to do.' However, with 'sense verbs' (like 吃, 喝, 看, 听, 闻) it means 'good to [sense]' (e.g., delicious, good-looking). 好玩 (hǎowán) is another common exception, meaning 'fun'."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-139-using-hao-to-mean-easy-001,
        srs-inst:sent-gp-a2-139-using-hao-to-mean-easy-002,
        srs-inst:sent-gp-a2-139-using-hao-to-mean-easy-003,
        srs-inst:sent-gp-a2-139-using-hao-to-mean-easy-004,
        srs-inst:sent-gp-a2-139-using-hao-to-mean-easy-005,
        srs-inst:sent-gp-a2-139-using-hao-to-mean-easy-006 ;
    srs-kg:structure "好 + Verb or Subj. + (很) 好 + Verb" .

srs-inst:gp-not-specified-119-comparisons-with-bi-and-geng a srs-kg:GrammarPoint ;
    rdfs:label "Comparisons with 'bi' and 'geng'"@en ;
    srs-kg:cefrLevel "Not specified" ;
    srs-kg:explanation "This pattern is an extension of the basic 比 (bǐ) comparison, adding 更 (gèng) before the adjective to mean 'even more'. It implies that while the second item (Noun 2) is already [adjective], the first item (Noun 1) is even more so."@en ;
    srs-kg:hasExample srs-inst:sent-gp-not-specified-119-comparisons-with-bi-and-geng-001,
        srs-inst:sent-gp-not-specified-119-comparisons-with-bi-and-geng-002,
        srs-inst:sent-gp-not-specified-119-comparisons-with-bi-and-geng-003,
        srs-inst:sent-gp-not-specified-119-comparisons-with-bi-and-geng-004,
        srs-inst:sent-gp-not-specified-119-comparisons-with-bi-and-geng-005,
        srs-inst:sent-gp-not-specified-119-comparisons-with-bi-and-geng-006 ;
    srs-kg:structure "Noun 1 + 比 + Noun 2 + 更 + Adj." .

srs-inst:gp-a2-114-structural-particle-%E7%9A%84-de-before-nouns a srs-kg:GrammarPoint ;
    rdfs:label "Structural particle 的 (de) before nouns"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "This form of 'de' is used to mark possession or modification. It works like ''s' in English for possession, but is also used more broadly to connect adjectives or other descriptive words with a noun, giving more information about it."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-114-structural-particle-%E7%9A%84-de-before-nouns-001,
        srs-inst:sent-gp-a2-114-structural-particle-%E7%9A%84-de-before-nouns-002,
        srs-inst:sent-gp-a2-114-structural-particle-%E7%9A%84-de-before-nouns-003,
        srs-inst:sent-gp-a2-114-structural-particle-%E7%9A%84-de-before-nouns-004,
        srs-inst:sent-gp-a2-114-structural-particle-%E7%9A%84-de-before-nouns-005,
        srs-inst:sent-gp-a2-114-structural-particle-%E7%9A%84-de-before-nouns-006,
        srs-inst:sent-gp-a2-114-structural-particle-%E7%9A%84-de-before-nouns-007 ;
    srs-kg:structure "Modifier + 的 + Noun" .

srs-inst:gp-a2-118-basic-comparisons-with-bi a srs-kg:GrammarPoint ;
    rdfs:label "Basic comparisons with 'bi'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The word 比 (bǐ) is used for comparisons, similar to 'than' in English. In this structure, the first noun is the one that possesses more of the quality described by the adjective compared to the second noun."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-118-basic-comparisons-with-bi-001,
        srs-inst:sent-gp-a2-118-basic-comparisons-with-bi-002,
        srs-inst:sent-gp-a2-118-basic-comparisons-with-bi-003,
        srs-inst:sent-gp-a2-118-basic-comparisons-with-bi-004,
        srs-inst:sent-gp-a2-118-basic-comparisons-with-bi-005,
        srs-inst:sent-gp-a2-118-basic-comparisons-with-bi-006,
        srs-inst:sent-gp-a2-118-basic-comparisons-with-bi-007 ;
    srs-kg:structure "Noun 1 + 比 + Noun 2 + Adj." .

srs-inst:gp-a1-010-the-all-adverb-dou a srs-kg:GrammarPoint ;
    rdfs:label "The \"all\" adverb \"dou\""@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The adverb 都 (dōu) is used to express \"all\". It is placed after the subject and before the verb. Unlike English, Chinese uses 都 (dōu) for quantities of two to mean \"both,\" and its negative form can express \"neither/nor.\""@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-010-the-all-adverb-dou-001,
        srs-inst:sent-gp-a1-010-the-all-adverb-dou-002,
        srs-inst:sent-gp-a1-010-the-all-adverb-dou-003,
        srs-inst:sent-gp-a1-010-the-all-adverb-dou-004,
        srs-inst:sent-gp-a1-010-the-all-adverb-dou-005,
        srs-inst:sent-gp-a1-010-the-all-adverb-dou-006,
        srs-inst:sent-gp-a1-010-the-all-adverb-dou-007,
        srs-inst:sent-gp-a1-010-the-all-adverb-dou-008 ;
    srs-kg:structure "Subject + 都 + [Verb Phrase]" .

srs-inst:gp-a1-012-expressing-and-with-he-%E5%92%8C a srs-kg:GrammarPoint ;
    rdfs:label "Expressing 'and' with 'he' (和)"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The word 和 (hé) is used to express 'and' in Chinese. It is primarily used to link nouns or noun phrases, and should not be used to connect verbs or whole sentences."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-012-expressing-and-with-he-%E5%92%8C-001,
        srs-inst:sent-gp-a1-012-expressing-and-with-he-%E5%92%8C-002,
        srs-inst:sent-gp-a1-012-expressing-and-with-he-%E5%92%8C-003,
        srs-inst:sent-gp-a1-012-expressing-and-with-he-%E5%92%8C-004,
        srs-inst:sent-gp-a1-012-expressing-and-with-he-%E5%92%8C-005,
        srs-inst:sent-gp-a1-012-expressing-and-with-he-%E5%92%8C-006,
        srs-inst:sent-gp-a1-012-expressing-and-with-he-%E5%92%8C-007,
        srs-inst:sent-gp-a1-012-expressing-and-with-he-%E5%92%8C-008 ;
    srs-kg:structure "Noun 1 + 和 + Noun 2" .

srs-inst:gp-a2-137-special-verbs-with-hen a srs-kg:GrammarPoint ;
    rdfs:label "Special verbs with 'hen'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "Certain 'psychological verbs' related to feelings or emotional states can be modified with 很 (hěn) to increase their intensity, similar to using 'really' or 'very much' in English. This applies to verbs like 想 (xiǎng), 喜欢 (xǐhuan), 怕 (pà), 了解 (liǎojiě), 讨厌 (tǎoyàn), 担心 (dānxīn), and 希望 (xīwàng)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-137-special-verbs-with-hen-001,
        srs-inst:sent-gp-a2-137-special-verbs-with-hen-002,
        srs-inst:sent-gp-a2-137-special-verbs-with-hen-003,
        srs-inst:sent-gp-a2-137-special-verbs-with-hen-004,
        srs-inst:sent-gp-a2-137-special-verbs-with-hen-005,
        srs-inst:sent-gp-a2-137-special-verbs-with-hen-006,
        srs-inst:sent-gp-a2-137-special-verbs-with-hen-007,
        srs-inst:sent-gp-a2-137-special-verbs-with-hen-008 ;
    srs-kg:structure "Subj. + 很 + [Certain Verbs] + [General Verbs/Nouns]" .

srs-inst:gp-a1-041-wanting-to-do-something-with-yao a srs-kg:GrammarPoint ;
    rdfs:label "Wanting to do something with 'yao'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The auxiliary verb 要 (yào) is used before a verb to express 'wanting to do' something. It often implies a stronger intention or plan to take action compared to 想 (xiǎng), which can mean 'would like to' and might just be an idea. 要 (yào) can sometimes sound more demanding."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-041-wanting-to-do-something-with-yao-001,
        srs-inst:sent-gp-a1-041-wanting-to-do-something-with-yao-002,
        srs-inst:sent-gp-a1-041-wanting-to-do-something-with-yao-003,
        srs-inst:sent-gp-a1-041-wanting-to-do-something-with-yao-004,
        srs-inst:sent-gp-a1-041-wanting-to-do-something-with-yao-005,
        srs-inst:sent-gp-a1-041-wanting-to-do-something-with-yao-006,
        srs-inst:sent-gp-a1-041-wanting-to-do-something-with-yao-007,
        srs-inst:sent-gp-a1-041-wanting-to-do-something-with-yao-008,
        srs-inst:sent-gp-a1-041-wanting-to-do-something-with-yao-009 ;
    srs-kg:structure "Subj. + 要 + Verb + Obj." .

srs-inst:gp-a2-132-expressing-ongoing-duration-with-double-le a srs-kg:GrammarPoint ;
    rdfs:label "Expressing ongoing duration with double \"le\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "To express the duration of an activity that started in the past and is still ongoing, use a double 'le' structure. One 了 is placed after the verb, followed by the duration, and a second 了 is placed at the end of the sentence. The second 了 communicates the meaning of 'up until now'. When the verb has an object, the verb is often repeated before the first 了."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-132-expressing-ongoing-duration-with-double-le-001,
        srs-inst:sent-gp-a2-132-expressing-ongoing-duration-with-double-le-002,
        srs-inst:sent-gp-a2-132-expressing-ongoing-duration-with-double-le-003,
        srs-inst:sent-gp-a2-132-expressing-ongoing-duration-with-double-le-004,
        srs-inst:sent-gp-a2-132-expressing-ongoing-duration-with-double-le-005,
        srs-inst:sent-gp-a2-132-expressing-ongoing-duration-with-double-le-006,
        srs-inst:sent-gp-a2-132-expressing-ongoing-duration-with-double-le-007,
        srs-inst:sent-gp-a2-132-expressing-ongoing-duration-with-double-le-008,
        srs-inst:sent-gp-a2-132-expressing-ongoing-duration-with-double-le-009 ;
    srs-kg:structure """With single verbs: Subj. + Verb + 了 + Duration + 了
When the verb takes an object: Subj. + Verb + Obj. + Verb + 了 + Duration + 了""" .

srs-inst:gp-a1-013-offering-choices-with-haishi-%E8%BF%98%E6%98%AF a srs-kg:GrammarPoint ;
    rdfs:label "Offering choices with 'haishi' (还是)"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "还是 (háishì) is used to offer options in a question, equivalent to 'or' in English questions. The questioner expects the listener to choose one of the provided options. It is important to note that 还是 (háishì) is only used for questions, not for 'or' in statements."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-013-offering-choices-with-haishi-%E8%BF%98%E6%98%AF-001,
        srs-inst:sent-gp-a1-013-offering-choices-with-haishi-%E8%BF%98%E6%98%AF-002,
        srs-inst:sent-gp-a1-013-offering-choices-with-haishi-%E8%BF%98%E6%98%AF-003,
        srs-inst:sent-gp-a1-013-offering-choices-with-haishi-%E8%BF%98%E6%98%AF-004,
        srs-inst:sent-gp-a1-013-offering-choices-with-haishi-%E8%BF%98%E6%98%AF-005,
        srs-inst:sent-gp-a1-013-offering-choices-with-haishi-%E8%BF%98%E6%98%AF-006,
        srs-inst:sent-gp-a1-013-offering-choices-with-haishi-%E8%BF%98%E6%98%AF-007,
        srs-inst:sent-gp-a1-013-offering-choices-with-haishi-%E8%BF%98%E6%98%AF-008,
        srs-inst:sent-gp-a1-013-offering-choices-with-haishi-%E8%BF%98%E6%98%AF-009,
        srs-inst:sent-gp-a1-013-offering-choices-with-haishi-%E8%BF%98%E6%98%AF-010 ;
    srs-kg:structure """Option A + 还是 + Option B ?
Subject + Verb + Option A + 还是 + Option B ?""" .

srs-inst:gp-a1-016-structure-of-dates a srs-kg:GrammarPoint ;
    rdfs:label "Structure of dates"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "Dates in Chinese follow the 'big to small' principle, ordered as year (年 nián), month (月 yuè), and day (日 rì / 号 hào). While 日 (rì) is used in written Chinese, 号 (hào) is more common in spoken Mandarin."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-016-structure-of-dates-001,
        srs-inst:sent-gp-a1-016-structure-of-dates-002,
        srs-inst:sent-gp-a1-016-structure-of-dates-003,
        srs-inst:sent-gp-a1-016-structure-of-dates-004,
        srs-inst:sent-gp-a1-016-structure-of-dates-005,
        srs-inst:sent-gp-a1-016-structure-of-dates-006,
        srs-inst:sent-gp-a1-016-structure-of-dates-007,
        srs-inst:sent-gp-a1-016-structure-of-dates-008,
        srs-inst:sent-gp-a1-016-structure-of-dates-009,
        srs-inst:sent-gp-a1-016-structure-of-dates-010 ;
    srs-kg:structure "x 年 + y 月 + z 日 / 号" .

srs-inst:gp-a1-020-expressing-numbers-with-hundreds-and-a-middle-zero a srs-kg:GrammarPoint ;
    rdfs:label "Expressing numbers with hundreds and a middle zero"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "When a number in the hundreds has a zero in the tens place (e.g., 101, 205), the zero must be read aloud as 零 (líng)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-020-expressing-numbers-with-hundreds-and-a-middle-zero-001,
        srs-inst:sent-gp-a1-020-expressing-numbers-with-hundreds-and-a-middle-zero-002,
        srs-inst:sent-gp-a1-020-expressing-numbers-with-hundreds-and-a-middle-zero-003,
        srs-inst:sent-gp-a1-020-expressing-numbers-with-hundreds-and-a-middle-zero-004,
        srs-inst:sent-gp-a1-020-expressing-numbers-with-hundreds-and-a-middle-zero-005,
        srs-inst:sent-gp-a1-020-expressing-numbers-with-hundreds-and-a-middle-zero-006,
        srs-inst:sent-gp-a1-020-expressing-numbers-with-hundreds-and-a-middle-zero-007,
        srs-inst:sent-gp-a1-020-expressing-numbers-with-hundreds-and-a-middle-zero-008,
        srs-inst:sent-gp-a1-020-expressing-numbers-with-hundreds-and-a-middle-zero-009,
        srs-inst:sent-gp-a1-020-expressing-numbers-with-hundreds-and-a-middle-zero-010 ;
    srs-kg:structure "x + 百 + 零 + y" .

srs-inst:gp-a1-021-expressing-numbers-from-110-to-999 a srs-kg:GrammarPoint ;
    rdfs:label "Expressing numbers from 110 to 999"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "For numbers greater than 100, the structure is x-hundred, y-ten, z. For numbers ending in the teens (e.g., 111-119), 'ten' is pronounced 一十 (yīshí). For numbers ending in a tens digit like 150, it can be read as 一百五十 (yībǎi wǔshí) or colloquially as 一百五 (yībǎi wǔ)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-021-expressing-numbers-from-110-to-999-001,
        srs-inst:sent-gp-a1-021-expressing-numbers-from-110-to-999-002,
        srs-inst:sent-gp-a1-021-expressing-numbers-from-110-to-999-003,
        srs-inst:sent-gp-a1-021-expressing-numbers-from-110-to-999-004,
        srs-inst:sent-gp-a1-021-expressing-numbers-from-110-to-999-005,
        srs-inst:sent-gp-a1-021-expressing-numbers-from-110-to-999-006,
        srs-inst:sent-gp-a1-021-expressing-numbers-from-110-to-999-007,
        srs-inst:sent-gp-a1-021-expressing-numbers-from-110-to-999-008,
        srs-inst:sent-gp-a1-021-expressing-numbers-from-110-to-999-009,
        srs-inst:sent-gp-a1-021-expressing-numbers-from-110-to-999-010 ;
    srs-kg:structure "x + 百 + y + 十 + z" .

srs-inst:gp-a1-022-expressing-numbers-with-thousands a srs-kg:GrammarPoint ;
    rdfs:label "Expressing numbers with thousands"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "千 (qiān) means 'thousand'. Its usage rules are similar to 'hundred'. No matter how many zeros are in the middle of the number, you only say 零 (líng) once."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-022-expressing-numbers-with-thousands-001,
        srs-inst:sent-gp-a1-022-expressing-numbers-with-thousands-002,
        srs-inst:sent-gp-a1-022-expressing-numbers-with-thousands-003,
        srs-inst:sent-gp-a1-022-expressing-numbers-with-thousands-004,
        srs-inst:sent-gp-a1-022-expressing-numbers-with-thousands-005,
        srs-inst:sent-gp-a1-022-expressing-numbers-with-thousands-006,
        srs-inst:sent-gp-a1-022-expressing-numbers-with-thousands-007,
        srs-inst:sent-gp-a1-022-expressing-numbers-with-thousands-008,
        srs-inst:sent-gp-a1-022-expressing-numbers-with-thousands-009,
        srs-inst:sent-gp-a1-022-expressing-numbers-with-thousands-010 ;
    srs-kg:structure "(digit) + 千 + ..." .

srs-inst:gp-a1-025-expressing-close-possession-without-de a srs-kg:GrammarPoint ;
    rdfs:label "Expressing close possession without 'de'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The possessive particle 的 (de) is typically omitted when there is a close personal relationship (e.g., family, partner) or an institutional relationship (e.g., my school, their company) between the possessor and the possessed. Leaving out 'de' sounds more natural in these contexts."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-025-expressing-close-possession-without-de-001,
        srs-inst:sent-gp-a1-025-expressing-close-possession-without-de-002,
        srs-inst:sent-gp-a1-025-expressing-close-possession-without-de-003,
        srs-inst:sent-gp-a1-025-expressing-close-possession-without-de-004,
        srs-inst:sent-gp-a1-025-expressing-close-possession-without-de-005,
        srs-inst:sent-gp-a1-025-expressing-close-possession-without-de-006,
        srs-inst:sent-gp-a1-025-expressing-close-possession-without-de-007,
        srs-inst:sent-gp-a1-025-expressing-close-possession-without-de-008,
        srs-inst:sent-gp-a1-025-expressing-close-possession-without-de-009,
        srs-inst:sent-gp-a1-025-expressing-close-possession-without-de-010 ;
    srs-kg:structure "Pronoun + Noun" .

srs-inst:gp-a1-026-expressing-possession-with-de a srs-kg:GrammarPoint ;
    rdfs:label "Expressing possession with 'de'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The particle 的 (de) indicates possession. It is placed after the possessor (Noun 1) and before the possessed item or person (Noun 2), similar to 's in English."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-026-expressing-possession-with-de-001,
        srs-inst:sent-gp-a1-026-expressing-possession-with-de-002,
        srs-inst:sent-gp-a1-026-expressing-possession-with-de-003,
        srs-inst:sent-gp-a1-026-expressing-possession-with-de-004,
        srs-inst:sent-gp-a1-026-expressing-possession-with-de-005,
        srs-inst:sent-gp-a1-026-expressing-possession-with-de-006,
        srs-inst:sent-gp-a1-026-expressing-possession-with-de-007,
        srs-inst:sent-gp-a1-026-expressing-possession-with-de-008,
        srs-inst:sent-gp-a1-026-expressing-possession-with-de-009,
        srs-inst:sent-gp-a1-026-expressing-possession-with-de-010 ;
    srs-kg:structure "Noun 1 + 的 + Noun 2" .

srs-inst:gp-a1-029-making-suggestions-with-ba a srs-kg:GrammarPoint ;
    rdfs:label "Making suggestions with 'ba'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "Adding the particle 吧 (ba) to the end of a sentence softens the tone, turning a command into a polite suggestion. With 我们 (wǒmen), it forms a 'let's...' suggestion."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-029-making-suggestions-with-ba-001,
        srs-inst:sent-gp-a1-029-making-suggestions-with-ba-002,
        srs-inst:sent-gp-a1-029-making-suggestions-with-ba-003,
        srs-inst:sent-gp-a1-029-making-suggestions-with-ba-004,
        srs-inst:sent-gp-a1-029-making-suggestions-with-ba-005,
        srs-inst:sent-gp-a1-029-making-suggestions-with-ba-006,
        srs-inst:sent-gp-a1-029-making-suggestions-with-ba-007,
        srs-inst:sent-gp-a1-029-making-suggestions-with-ba-008,
        srs-inst:sent-gp-a1-029-making-suggestions-with-ba-009,
        srs-inst:sent-gp-a1-029-making-suggestions-with-ba-010 ;
    srs-kg:structure "Command + 吧" .

srs-inst:gp-a1-030-expressing-existence-in-a-place-with-zai a srs-kg:GrammarPoint ;
    rdfs:label "Expressing existence in a place with 'zai'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The verb 在 (zài) indicates the existence of a subject in a specific location, corresponding to the English 'to be in' or 'to be at'. The verb 是 (shì) is not used in this pattern."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-030-expressing-existence-in-a-place-with-zai-001,
        srs-inst:sent-gp-a1-030-expressing-existence-in-a-place-with-zai-002,
        srs-inst:sent-gp-a1-030-expressing-existence-in-a-place-with-zai-003,
        srs-inst:sent-gp-a1-030-expressing-existence-in-a-place-with-zai-004,
        srs-inst:sent-gp-a1-030-expressing-existence-in-a-place-with-zai-005,
        srs-inst:sent-gp-a1-030-expressing-existence-in-a-place-with-zai-006,
        srs-inst:sent-gp-a1-030-expressing-existence-in-a-place-with-zai-007,
        srs-inst:sent-gp-a1-030-expressing-existence-in-a-place-with-zai-008,
        srs-inst:sent-gp-a1-030-expressing-existence-in-a-place-with-zai-009,
        srs-inst:sent-gp-a1-030-expressing-existence-in-a-place-with-zai-010 ;
    srs-kg:structure "Subj. + 在 + Place" .

srs-inst:gp-a1-031-expressing-existence-with-you a srs-kg:GrammarPoint ;
    rdfs:label "Expressing existence with \"you\""@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The verb 有 (yǒu), which means \"to have,\" can also be used to express existence. This is similar to saying \"there is\" or \"there are\" in English."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-031-expressing-existence-with-you-001,
        srs-inst:sent-gp-a1-031-expressing-existence-with-you-002,
        srs-inst:sent-gp-a1-031-expressing-existence-with-you-003,
        srs-inst:sent-gp-a1-031-expressing-existence-with-you-004,
        srs-inst:sent-gp-a1-031-expressing-existence-with-you-005,
        srs-inst:sent-gp-a1-031-expressing-existence-with-you-006,
        srs-inst:sent-gp-a1-031-expressing-existence-with-you-007,
        srs-inst:sent-gp-a1-031-expressing-existence-with-you-008,
        srs-inst:sent-gp-a1-031-expressing-existence-with-you-009,
        srs-inst:sent-gp-a1-031-expressing-existence-with-you-010 ;
    srs-kg:structure "Place + 有 + Obj." .

srs-inst:gp-a1-032-expressing-possession-with-you a srs-kg:GrammarPoint ;
    rdfs:label "Expressing possession with \"you\""@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "有 (yǒu) can be used in various ways, but the most basic meaning of this verb you need to know is \"to have.\" The verb 有 (yǒu) is negated in a special way. Unlike most verbs, it is negated with 没 (méi), instead of 不 (bù). The negative form of 有 (yǒu) then, is 没有 (méiyǒu)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-032-expressing-possession-with-you-001,
        srs-inst:sent-gp-a1-032-expressing-possession-with-you-002,
        srs-inst:sent-gp-a1-032-expressing-possession-with-you-003,
        srs-inst:sent-gp-a1-032-expressing-possession-with-you-004,
        srs-inst:sent-gp-a1-032-expressing-possession-with-you-005,
        srs-inst:sent-gp-a1-032-expressing-possession-with-you-006,
        srs-inst:sent-gp-a1-032-expressing-possession-with-you-007,
        srs-inst:sent-gp-a1-032-expressing-possession-with-you-008,
        srs-inst:sent-gp-a1-032-expressing-possession-with-you-009,
        srs-inst:sent-gp-a1-032-expressing-possession-with-you-010 ;
    srs-kg:structure "Subj. + 有 + Obj." .

srs-inst:gp-a1-036-expressing-be-going-to-with-yao a srs-kg:GrammarPoint ;
    rdfs:label "Expressing \"be going to\" with \"yao\""@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The auxiliary verb 要 (yào) has several different meanings, and here we'll tackle the \"be going to\" meaning. You'll use this when you are discussing your plans with someone. The idea behind this usage of 要 (yào) is that someone is \"planning to\" or \"going to\" or \"preparing to\" do something. It's not that they just want to, or have to, it's that they fully expect to do it. It's in their plan. This usage of 要 (yào) typically includes a time word of some sort, which may be placed before or after the subject."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-036-expressing-be-going-to-with-yao-001,
        srs-inst:sent-gp-a1-036-expressing-be-going-to-with-yao-002,
        srs-inst:sent-gp-a1-036-expressing-be-going-to-with-yao-003,
        srs-inst:sent-gp-a1-036-expressing-be-going-to-with-yao-004,
        srs-inst:sent-gp-a1-036-expressing-be-going-to-with-yao-005,
        srs-inst:sent-gp-a1-036-expressing-be-going-to-with-yao-006,
        srs-inst:sent-gp-a1-036-expressing-be-going-to-with-yao-007,
        srs-inst:sent-gp-a1-036-expressing-be-going-to-with-yao-008,
        srs-inst:sent-gp-a1-036-expressing-be-going-to-with-yao-009,
        srs-inst:sent-gp-a1-036-expressing-be-going-to-with-yao-010 ;
    srs-kg:structure "Subj. + 要 + Verb" .

srs-inst:gp-a1-037-expressing-a-learned-skill-with-hui a srs-kg:GrammarPoint ;
    rdfs:label "Expressing a learned skill with \"hui\""@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The word 会 (huì) can be used to express an ability that has been learned (a skill). In this case 会 (huì) is an auxiliary verb. This structure is the easiest way to express all kinds of skills, from languages, to sports, to skills in daily life such as cooking, and driving. 会 (huì) sentences are negated with 不 (bù), which is inserted in front of 会 (huì). So while \"can't\" is a natural translation for \"不会\" (bù huì) in English, \"don't know how to\" is equally correct (and perhaps more helpful). Also, due to a tone change rule for \"不\" (bù), the phrase \"不会\" (bù huì) is actually read as \"bú huì\"."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-037-expressing-a-learned-skill-with-hui-001,
        srs-inst:sent-gp-a1-037-expressing-a-learned-skill-with-hui-002,
        srs-inst:sent-gp-a1-037-expressing-a-learned-skill-with-hui-003,
        srs-inst:sent-gp-a1-037-expressing-a-learned-skill-with-hui-004,
        srs-inst:sent-gp-a1-037-expressing-a-learned-skill-with-hui-005,
        srs-inst:sent-gp-a1-037-expressing-a-learned-skill-with-hui-006,
        srs-inst:sent-gp-a1-037-expressing-a-learned-skill-with-hui-007,
        srs-inst:sent-gp-a1-037-expressing-a-learned-skill-with-hui-008,
        srs-inst:sent-gp-a1-037-expressing-a-learned-skill-with-hui-009,
        srs-inst:sent-gp-a1-037-expressing-a-learned-skill-with-hui-010 ;
    srs-kg:structure "Subj. + 会 + Verb + Obj. / (Negation) Subj. + 不 + 会 + Verb + Obj." .

srs-inst:gp-a1-042-how-to-do-something-with-zenme a srs-kg:GrammarPoint ;
    rdfs:label "How to do something with 'zenme'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The question word 怎么 (zěnme) means 'how' and is placed before the verb to ask about the manner or method of an action. It's common to either have the subject perform the action (Subj. + 怎么 + Verb) or to make the object the topic of the sentence by placing it at the beginning (Topic + 怎么 + Verb)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-042-how-to-do-something-with-zenme-001,
        srs-inst:sent-gp-a1-042-how-to-do-something-with-zenme-002,
        srs-inst:sent-gp-a1-042-how-to-do-something-with-zenme-003,
        srs-inst:sent-gp-a1-042-how-to-do-something-with-zenme-004,
        srs-inst:sent-gp-a1-042-how-to-do-something-with-zenme-005,
        srs-inst:sent-gp-a1-042-how-to-do-something-with-zenme-006,
        srs-inst:sent-gp-a1-042-how-to-do-something-with-zenme-007,
        srs-inst:sent-gp-a1-042-how-to-do-something-with-zenme-008,
        srs-inst:sent-gp-a1-042-how-to-do-something-with-zenme-009,
        srs-inst:sent-gp-a1-042-how-to-do-something-with-zenme-010 ;
    srs-kg:structure "Subj. + 怎么 + Verb + Obj. / Topic + 怎么 + Verb" .

srs-inst:gp-a1-044-negative-commands-with-buyao a srs-kg:GrammarPoint ;
    rdfs:label "Negative commands with 'buyao'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "To give a negative command, meaning 'don't do something', use 不要 (bùyào) before the verb. The subject is often omitted, similar to English commands. This is a common way to tell someone not to perform an action."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-044-negative-commands-with-buyao-001,
        srs-inst:sent-gp-a1-044-negative-commands-with-buyao-002,
        srs-inst:sent-gp-a1-044-negative-commands-with-buyao-003,
        srs-inst:sent-gp-a1-044-negative-commands-with-buyao-004,
        srs-inst:sent-gp-a1-044-negative-commands-with-buyao-005,
        srs-inst:sent-gp-a1-044-negative-commands-with-buyao-006,
        srs-inst:sent-gp-a1-044-negative-commands-with-buyao-007,
        srs-inst:sent-gp-a1-044-negative-commands-with-buyao-008,
        srs-inst:sent-gp-a1-044-negative-commands-with-buyao-009,
        srs-inst:sent-gp-a1-044-negative-commands-with-buyao-010 ;
    srs-kg:structure "不要 + Verb" .

srs-inst:gp-a1-046-basic-sentence-order a srs-kg:GrammarPoint ;
    rdfs:label "Basic sentence order"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The most basic sentence order in Chinese is Subject-Verb-Object (SVO), which is the same as in English. This simple structure can be used to form a wide variety of sentences, starting with a subject and a verb, and often including an object that receives the action of the verb."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-046-basic-sentence-order-001,
        srs-inst:sent-gp-a1-046-basic-sentence-order-002,
        srs-inst:sent-gp-a1-046-basic-sentence-order-003,
        srs-inst:sent-gp-a1-046-basic-sentence-order-004,
        srs-inst:sent-gp-a1-046-basic-sentence-order-005,
        srs-inst:sent-gp-a1-046-basic-sentence-order-006,
        srs-inst:sent-gp-a1-046-basic-sentence-order-007,
        srs-inst:sent-gp-a1-046-basic-sentence-order-008,
        srs-inst:sent-gp-a1-046-basic-sentence-order-009,
        srs-inst:sent-gp-a1-046-basic-sentence-order-010 ;
    srs-kg:structure "Subj. + Verb (+ Obj.)" .

srs-inst:gp-a1-047-connecting-nouns-with-shi a srs-kg:GrammarPoint ;
    rdfs:label "Connecting nouns with 'shi'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The verb 是 (shì) is used to link two nouns, noun phrases, or pronouns, equivalent to the verb 'to be' in English (am, is, are). It establishes an identity between the two nouns. Importantly, 是 is generally not used to link a noun with an adjective. It can also be used in question patterns like '是不是 (shì bù shì)?' (right?) and as a tag question '是吗? (shì ma?)' (is it?)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-047-connecting-nouns-with-shi-001,
        srs-inst:sent-gp-a1-047-connecting-nouns-with-shi-002,
        srs-inst:sent-gp-a1-047-connecting-nouns-with-shi-003,
        srs-inst:sent-gp-a1-047-connecting-nouns-with-shi-004,
        srs-inst:sent-gp-a1-047-connecting-nouns-with-shi-005,
        srs-inst:sent-gp-a1-047-connecting-nouns-with-shi-006,
        srs-inst:sent-gp-a1-047-connecting-nouns-with-shi-007,
        srs-inst:sent-gp-a1-047-connecting-nouns-with-shi-008,
        srs-inst:sent-gp-a1-047-connecting-nouns-with-shi-009,
        srs-inst:sent-gp-a1-047-connecting-nouns-with-shi-010 ;
    srs-kg:structure "Noun 1 + 是 + Noun 2" .

srs-inst:gp-a1-053-tag-questions-with-bu a srs-kg:GrammarPoint ;
    rdfs:label "Tag questions with 'bu'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "In the same way you can tag questions with 吗 (ma), tag questions can also be formed using 不 (bù). This is done by putting an affirmative-negative question at the end of a sentence. Tag questions seek confirmation or acceptance of what has been said. In English, \"right?\" and \"OK?\" are often used as tag questions."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-053-tag-questions-with-bu-001,
        srs-inst:sent-gp-a1-053-tag-questions-with-bu-002,
        srs-inst:sent-gp-a1-053-tag-questions-with-bu-003,
        srs-inst:sent-gp-a1-053-tag-questions-with-bu-004,
        srs-inst:sent-gp-a1-053-tag-questions-with-bu-005,
        srs-inst:sent-gp-a1-053-tag-questions-with-bu-006,
        srs-inst:sent-gp-a1-053-tag-questions-with-bu-007,
        srs-inst:sent-gp-a1-053-tag-questions-with-bu-008,
        srs-inst:sent-gp-a1-053-tag-questions-with-bu-009,
        srs-inst:sent-gp-a1-053-tag-questions-with-bu-010 ;
    srs-kg:structure "Sentence, Verb + 不 + Verb?" .

srs-inst:gp-a1-054-tag-questions-with-ma a srs-kg:GrammarPoint ;
    rdfs:label "Tag questions with 'ma'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "As well as yes / no questions, you can also form tag questions with 吗 (ma). Tag questions are quick questions that are tagged on the end of a sentence to ask for confirmation. In English, this is often done with \"right?\", or negatively with \"isn't it?\" The easiest way to do this in Chinese is to add some kind of confirmation word and 吗 (ma) on the end of the sentence. By placing these on the end of a sentence, you can soften a suggestion or request confirmation."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-054-tag-questions-with-ma-001,
        srs-inst:sent-gp-a1-054-tag-questions-with-ma-002,
        srs-inst:sent-gp-a1-054-tag-questions-with-ma-003,
        srs-inst:sent-gp-a1-054-tag-questions-with-ma-004,
        srs-inst:sent-gp-a1-054-tag-questions-with-ma-005,
        srs-inst:sent-gp-a1-054-tag-questions-with-ma-006,
        srs-inst:sent-gp-a1-054-tag-questions-with-ma-007,
        srs-inst:sent-gp-a1-054-tag-questions-with-ma-008,
        srs-inst:sent-gp-a1-054-tag-questions-with-ma-009,
        srs-inst:sent-gp-a1-054-tag-questions-with-ma-010 ;
    srs-kg:structure "……， 好 / 对 / 是 / 可以 + 吗？" .

srs-inst:gp-a2-061-expressing-all-along-with-yizhi a srs-kg:GrammarPoint ;
    rdfs:label "Expressing 'all along' with 'yizhi'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The adverb 一直 (yīzhí) can be used to express that you are doing something all along, have been continuously doing something since a certain time, or that something will continuously happen. It is frequently translated as 'always' in English."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-061-expressing-all-along-with-yizhi-001,
        srs-inst:sent-gp-a2-061-expressing-all-along-with-yizhi-002,
        srs-inst:sent-gp-a2-061-expressing-all-along-with-yizhi-003,
        srs-inst:sent-gp-a2-061-expressing-all-along-with-yizhi-004,
        srs-inst:sent-gp-a2-061-expressing-all-along-with-yizhi-005,
        srs-inst:sent-gp-a2-061-expressing-all-along-with-yizhi-006,
        srs-inst:sent-gp-a2-061-expressing-all-along-with-yizhi-007,
        srs-inst:sent-gp-a2-061-expressing-all-along-with-yizhi-008,
        srs-inst:sent-gp-a2-061-expressing-all-along-with-yizhi-009,
        srs-inst:sent-gp-a2-061-expressing-all-along-with-yizhi-010 ;
    srs-kg:structure "Subj. + 一直 + Predicate" .

srs-inst:gp-a2-063-expressing-always-with-zongshi a srs-kg:GrammarPoint ;
    rdfs:label "Expressing 'always' with 'zongshi'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The adverb 总是 (zǒngshì) means 'always' and is used to describe a daily routine, a habit, or something that consistently happens. It comes before the verb. When used with an adjective, a modifier like 很, 这么, or 那么 is needed between 总是 and the adjective."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-063-expressing-always-with-zongshi-001,
        srs-inst:sent-gp-a2-063-expressing-always-with-zongshi-002,
        srs-inst:sent-gp-a2-063-expressing-always-with-zongshi-003,
        srs-inst:sent-gp-a2-063-expressing-always-with-zongshi-004,
        srs-inst:sent-gp-a2-063-expressing-always-with-zongshi-005,
        srs-inst:sent-gp-a2-063-expressing-always-with-zongshi-006,
        srs-inst:sent-gp-a2-063-expressing-always-with-zongshi-007,
        srs-inst:sent-gp-a2-063-expressing-always-with-zongshi-008,
        srs-inst:sent-gp-a2-063-expressing-always-with-zongshi-009,
        srs-inst:sent-gp-a2-063-expressing-always-with-zongshi-010 ;
    srs-kg:structure "With verb: Subj. + 总是 + Verb. With adjective: 总是 + Modifier (e.g., 很, 这么) + Adj." .

srs-inst:gp-a2-064-expressing-and-also-with-hai a srs-kg:GrammarPoint ;
    rdfs:label "Expressing 'and also' with 'hai'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The adverb 还 (hái) can link two phrases to mean 'and also'. It's used when one subject performs two different actions or has two different attributes. This is different from 也 (yě), which is used when two different subjects perform the same action."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-064-expressing-and-also-with-hai-001,
        srs-inst:sent-gp-a2-064-expressing-and-also-with-hai-002,
        srs-inst:sent-gp-a2-064-expressing-and-also-with-hai-003,
        srs-inst:sent-gp-a2-064-expressing-and-also-with-hai-004,
        srs-inst:sent-gp-a2-064-expressing-and-also-with-hai-005,
        srs-inst:sent-gp-a2-064-expressing-and-also-with-hai-006,
        srs-inst:sent-gp-a2-064-expressing-and-also-with-hai-007,
        srs-inst:sent-gp-a2-064-expressing-and-also-with-hai-008,
        srs-inst:sent-gp-a2-064-expressing-and-also-with-hai-009,
        srs-inst:sent-gp-a2-064-expressing-and-also-with-hai-010 ;
    srs-kg:structure "Subj. + Verb + Obj. 1, 还 + Verb + Obj. 2" .

srs-inst:gp-a2-067-expressing-just-with-gang a srs-kg:GrammarPoint ;
    rdfs:label "Expressing 'just' with 'gang'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "刚 (gāng) or 刚刚 (gānggāng) is used to express an action that happened not long ago, equivalent to 'just' in English. It can also be used with a duration to specify how long ago the action happened, without needing a separate word for 'ago'."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-067-expressing-just-with-gang-001,
        srs-inst:sent-gp-a2-067-expressing-just-with-gang-002,
        srs-inst:sent-gp-a2-067-expressing-just-with-gang-003,
        srs-inst:sent-gp-a2-067-expressing-just-with-gang-004,
        srs-inst:sent-gp-a2-067-expressing-just-with-gang-005,
        srs-inst:sent-gp-a2-067-expressing-just-with-gang-006,
        srs-inst:sent-gp-a2-067-expressing-just-with-gang-007,
        srs-inst:sent-gp-a2-067-expressing-just-with-gang-008,
        srs-inst:sent-gp-a2-067-expressing-just-with-gang-009,
        srs-inst:sent-gp-a2-067-expressing-just-with-gang-010 ;
    srs-kg:structure "Subj. + 刚 / 刚刚 + Verb OR Subj. + 刚 + Verb (+ Obj.) + Duration" .

srs-inst:gp-a2-068-expressing-only-with-zhi a srs-kg:GrammarPoint ;
    rdfs:label "Expressing 'only' with 'zhi'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "只 (zhǐ) is the most basic adverb to express 'only'. It is normally placed before a verb or an auxiliary verb like 会 (huì) or 能 (néng)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-068-expressing-only-with-zhi-001,
        srs-inst:sent-gp-a2-068-expressing-only-with-zhi-002,
        srs-inst:sent-gp-a2-068-expressing-only-with-zhi-003,
        srs-inst:sent-gp-a2-068-expressing-only-with-zhi-004,
        srs-inst:sent-gp-a2-068-expressing-only-with-zhi-005,
        srs-inst:sent-gp-a2-068-expressing-only-with-zhi-006,
        srs-inst:sent-gp-a2-068-expressing-only-with-zhi-007,
        srs-inst:sent-gp-a2-068-expressing-only-with-zhi-008,
        srs-inst:sent-gp-a2-068-expressing-only-with-zhi-009,
        srs-inst:sent-gp-a2-068-expressing-only-with-zhi-010 ;
    srs-kg:structure "只 + Verb OR 只 + Aux. Verb (+ Verb)" .

srs-inst:gp-a2-069-expressing-actions-in-progress a srs-kg:GrammarPoint ;
    rdfs:label "Expressing actions in progress"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "在 (zài) and 正在 (zhèngzài) are used as auxiliary verbs to express that an action is ongoing or in progress, similar to the present continuous in English. 正在 (zhèngzài) is used to put more emphasis on an action that is in progress right now (or at a specific moment in the past)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-069-expressing-actions-in-progress-001,
        srs-inst:sent-gp-a2-069-expressing-actions-in-progress-002,
        srs-inst:sent-gp-a2-069-expressing-actions-in-progress-003,
        srs-inst:sent-gp-a2-069-expressing-actions-in-progress-004,
        srs-inst:sent-gp-a2-069-expressing-actions-in-progress-005,
        srs-inst:sent-gp-a2-069-expressing-actions-in-progress-006,
        srs-inst:sent-gp-a2-069-expressing-actions-in-progress-007,
        srs-inst:sent-gp-a2-069-expressing-actions-in-progress-008,
        srs-inst:sent-gp-a2-069-expressing-actions-in-progress-009,
        srs-inst:sent-gp-a2-069-expressing-actions-in-progress-010 ;
    srs-kg:structure "Subj. + 在 + Verb + Obj. OR Subj. + 正在 + Verb + Obj." .

srs-inst:gp-a2-070-negative-commands-with-bie a srs-kg:GrammarPoint ;
    rdfs:label "Negative commands with 'bie'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "别 (bié) is used to form negative commands, meaning 'don't'. It's considered a quicker and more forceful way to give a negative command than 不要 (bùyào), and can be thought of as a contraction of it."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-070-negative-commands-with-bie-001,
        srs-inst:sent-gp-a2-070-negative-commands-with-bie-002,
        srs-inst:sent-gp-a2-070-negative-commands-with-bie-003,
        srs-inst:sent-gp-a2-070-negative-commands-with-bie-004,
        srs-inst:sent-gp-a2-070-negative-commands-with-bie-005,
        srs-inst:sent-gp-a2-070-negative-commands-with-bie-006,
        srs-inst:sent-gp-a2-070-negative-commands-with-bie-007,
        srs-inst:sent-gp-a2-070-negative-commands-with-bie-008,
        srs-inst:sent-gp-a2-070-negative-commands-with-bie-009,
        srs-inst:sent-gp-a2-070-negative-commands-with-bie-010 ;
    srs-kg:structure "别 + Verb + (Obj.)" .

srs-inst:gp-a2-071-simultaneous-tasks-with-yibian a srs-kg:GrammarPoint ;
    rdfs:label "Simultaneous tasks with 'yibian'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "To express that one thing is done while doing something else, the word 一边 (yībiān) is used. Both actions must be intentional and actively performed. 一边 (yībiān) can sometimes be shortened to 边 (biān) for a less formal feel. The 'main' action usually comes first in the Chinese sentence structure."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-071-simultaneous-tasks-with-yibian-001,
        srs-inst:sent-gp-a2-071-simultaneous-tasks-with-yibian-002,
        srs-inst:sent-gp-a2-071-simultaneous-tasks-with-yibian-003,
        srs-inst:sent-gp-a2-071-simultaneous-tasks-with-yibian-004,
        srs-inst:sent-gp-a2-071-simultaneous-tasks-with-yibian-005,
        srs-inst:sent-gp-a2-071-simultaneous-tasks-with-yibian-006,
        srs-inst:sent-gp-a2-071-simultaneous-tasks-with-yibian-007,
        srs-inst:sent-gp-a2-071-simultaneous-tasks-with-yibian-008,
        srs-inst:sent-gp-a2-071-simultaneous-tasks-with-yibian-009,
        srs-inst:sent-gp-a2-071-simultaneous-tasks-with-yibian-010 ;
    srs-kg:structure "Subj. + 一边 + Verb, + 一边 + Verb" .

srs-inst:gp-a2-072-asking-about-degree-with-duo a srs-kg:GrammarPoint ;
    rdfs:label "Asking about degree with 'duo'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "多 (duō) is used to ask questions about the degree or extent of an adjective, translating to 'How [adjective]...?' For example, it can be used to ask 'how tall?', 'how big?', or 'how old?'. When asking about age, '你多大?' (nǐ duōdà) is informal and typically used for friends or children."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-072-asking-about-degree-with-duo-001,
        srs-inst:sent-gp-a2-072-asking-about-degree-with-duo-002,
        srs-inst:sent-gp-a2-072-asking-about-degree-with-duo-003,
        srs-inst:sent-gp-a2-072-asking-about-degree-with-duo-004,
        srs-inst:sent-gp-a2-072-asking-about-degree-with-duo-005,
        srs-inst:sent-gp-a2-072-asking-about-degree-with-duo-006,
        srs-inst:sent-gp-a2-072-asking-about-degree-with-duo-007,
        srs-inst:sent-gp-a2-072-asking-about-degree-with-duo-008,
        srs-inst:sent-gp-a2-072-asking-about-degree-with-duo-009,
        srs-inst:sent-gp-a2-072-asking-about-degree-with-duo-010 ;
    srs-kg:structure "Subj. + 多 + Adj. ?" .

srs-inst:gp-a2-074-expressing-a-little-too-with-you-dian a srs-kg:GrammarPoint ;
    rdfs:label "Expressing 'a little too' with 'you dian'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "有点 (yǒudiǎn) or 有一点 (yǒu yīdiǎn) is used to say that something is 'a little too' or 'a bit too' much of a certain quality. It often carries a negative or unpleasant connotation for the speaker, expressing slight dissatisfaction or discomfort. In spoken Chinese, the 一 (yī) is often dropped. It is not used with positive adjectives like 'happy' or 'fun'."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-074-expressing-a-little-too-with-you-dian-001,
        srs-inst:sent-gp-a2-074-expressing-a-little-too-with-you-dian-002,
        srs-inst:sent-gp-a2-074-expressing-a-little-too-with-you-dian-003,
        srs-inst:sent-gp-a2-074-expressing-a-little-too-with-you-dian-004,
        srs-inst:sent-gp-a2-074-expressing-a-little-too-with-you-dian-005,
        srs-inst:sent-gp-a2-074-expressing-a-little-too-with-you-dian-006,
        srs-inst:sent-gp-a2-074-expressing-a-little-too-with-you-dian-007,
        srs-inst:sent-gp-a2-074-expressing-a-little-too-with-you-dian-008,
        srs-inst:sent-gp-a2-074-expressing-a-little-too-with-you-dian-009,
        srs-inst:sent-gp-a2-074-expressing-a-little-too-with-you-dian-010 ;
    srs-kg:structure "Subj. + 有点(儿) / 有一点(儿) + Adj." .

srs-inst:gp-a2-075-expressing-both-a-and-b-with-you a srs-kg:GrammarPoint ;
    rdfs:label "Expressing \"both A and B\" with \"you\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The character 又 (yòu) can be used to give two qualities to something. Using the double 又 (yòu) structure is like saying that something is \"both... and... \" in English. The two words shouldn't contrast in feeling. It is important to note they must both be bad or both be good."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-075-expressing-both-a-and-b-with-you-001,
        srs-inst:sent-gp-a2-075-expressing-both-a-and-b-with-you-002,
        srs-inst:sent-gp-a2-075-expressing-both-a-and-b-with-you-003,
        srs-inst:sent-gp-a2-075-expressing-both-a-and-b-with-you-004,
        srs-inst:sent-gp-a2-075-expressing-both-a-and-b-with-you-005,
        srs-inst:sent-gp-a2-075-expressing-both-a-and-b-with-you-006,
        srs-inst:sent-gp-a2-075-expressing-both-a-and-b-with-you-007,
        srs-inst:sent-gp-a2-075-expressing-both-a-and-b-with-you-008,
        srs-inst:sent-gp-a2-075-expressing-both-a-and-b-with-you-009,
        srs-inst:sent-gp-a2-075-expressing-both-a-and-b-with-you-010 ;
    srs-kg:structure "Subj. + 又 + Adj. 1 + 又 + Adj. 2" .

srs-inst:gp-a2-076-expressing-not-very-with-bu-tai a srs-kg:GrammarPoint ;
    rdfs:label "Expressing \"not very\" with \"bu tai\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "不太 (bù tài) means \"not very\" or \"not so\" (literally \"not too\"). Note that this pattern does not normally use 了 (le). This pattern can be used with adjectives and some psychological verbs (e.g. 喜欢 (xǐhuan), 想 (xiǎng), 明白 (míngbai))."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-076-expressing-not-very-with-bu-tai-001,
        srs-inst:sent-gp-a2-076-expressing-not-very-with-bu-tai-002,
        srs-inst:sent-gp-a2-076-expressing-not-very-with-bu-tai-003,
        srs-inst:sent-gp-a2-076-expressing-not-very-with-bu-tai-004,
        srs-inst:sent-gp-a2-076-expressing-not-very-with-bu-tai-005,
        srs-inst:sent-gp-a2-076-expressing-not-very-with-bu-tai-006,
        srs-inst:sent-gp-a2-076-expressing-not-very-with-bu-tai-007,
        srs-inst:sent-gp-a2-076-expressing-not-very-with-bu-tai-008,
        srs-inst:sent-gp-a2-076-expressing-not-very-with-bu-tai-009,
        srs-inst:sent-gp-a2-076-expressing-not-very-with-bu-tai-010 ;
    srs-kg:structure "Subj. + 不太 + Adj. / Verb" .

srs-inst:gp-a2-077-expressing-distance-with-li a srs-kg:GrammarPoint ;
    rdfs:label "Expressing distance with \"li\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "One of the ways to express distance is to use 离 (lí). You'll normally want to pair 离 (lí) with the adjective 近 (jìn) for \"close,\" or 远 (yuǎn) for \"far.\" This pattern is normally used to simply express that one place is (not) close or (not) far from another place."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-077-expressing-distance-with-li-001,
        srs-inst:sent-gp-a2-077-expressing-distance-with-li-002,
        srs-inst:sent-gp-a2-077-expressing-distance-with-li-003,
        srs-inst:sent-gp-a2-077-expressing-distance-with-li-004,
        srs-inst:sent-gp-a2-077-expressing-distance-with-li-005,
        srs-inst:sent-gp-a2-077-expressing-distance-with-li-006,
        srs-inst:sent-gp-a2-077-expressing-distance-with-li-007,
        srs-inst:sent-gp-a2-077-expressing-distance-with-li-008,
        srs-inst:sent-gp-a2-077-expressing-distance-with-li-009,
        srs-inst:sent-gp-a2-077-expressing-distance-with-li-010 ;
    srs-kg:structure "Place 1 + 离 + Place 2 + Adv. + 近 / 远" .

srs-inst:gp-a2-079-moderating-positive-adjectives-with-hai a srs-kg:GrammarPoint ;
    rdfs:label "Moderating positive adjectives with \"hai\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "Whenever you want to imply that something is \"good,\" but also kind of \"meh,\" you can use 还 (hái) in front of the \"good\" adjective. Besides expressing continuation, 还 (hái) can also be used to weaken positive adjectives. This is similar to saying \"fairly [good]\" or \"reasonably [good]\" in English. It's also sometimes used by a speaker to be more modest."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-079-moderating-positive-adjectives-with-hai-001,
        srs-inst:sent-gp-a2-079-moderating-positive-adjectives-with-hai-002,
        srs-inst:sent-gp-a2-079-moderating-positive-adjectives-with-hai-003,
        srs-inst:sent-gp-a2-079-moderating-positive-adjectives-with-hai-004,
        srs-inst:sent-gp-a2-079-moderating-positive-adjectives-with-hai-005,
        srs-inst:sent-gp-a2-079-moderating-positive-adjectives-with-hai-006,
        srs-inst:sent-gp-a2-079-moderating-positive-adjectives-with-hai-007,
        srs-inst:sent-gp-a2-079-moderating-positive-adjectives-with-hai-008,
        srs-inst:sent-gp-a2-079-moderating-positive-adjectives-with-hai-009,
        srs-inst:sent-gp-a2-079-moderating-positive-adjectives-with-hai-010 ;
    srs-kg:structure "Subj. + 还 + 好 / 可以 / 行 / 不错" .

srs-inst:gp-a2-080-modifying-nouns-with-adjective-de a srs-kg:GrammarPoint ;
    rdfs:label "Modifying nouns with adjective + \"de\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "By using 的 (de), we can connect descriptive adjectives to nouns. If the adjective has two characters (e.g. 漂亮 (piàoliang) or 高兴 (gāoxìng)), the 的 (de) is generally required. In some cases, it is possible to drop the noun from the pattern, and just use the adjective + 的 (de). This is kind of like saying \"the big one\" or \"the red one\" in English. The other person must be clear which \"one\" you're referring to."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-080-modifying-nouns-with-adjective-de-001,
        srs-inst:sent-gp-a2-080-modifying-nouns-with-adjective-de-002,
        srs-inst:sent-gp-a2-080-modifying-nouns-with-adjective-de-003,
        srs-inst:sent-gp-a2-080-modifying-nouns-with-adjective-de-004,
        srs-inst:sent-gp-a2-080-modifying-nouns-with-adjective-de-005,
        srs-inst:sent-gp-a2-080-modifying-nouns-with-adjective-de-006,
        srs-inst:sent-gp-a2-080-modifying-nouns-with-adjective-de-007,
        srs-inst:sent-gp-a2-080-modifying-nouns-with-adjective-de-008,
        srs-inst:sent-gp-a2-080-modifying-nouns-with-adjective-de-009,
        srs-inst:sent-gp-a2-080-modifying-nouns-with-adjective-de-010 ;
    srs-kg:structure "Adj. + 的 (+ Noun)" .

srs-inst:gp-a2-081-modifying-nouns-with-phrase-de a srs-kg:GrammarPoint ;
    rdfs:label "Modifying nouns with phrase + \"de\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "In addition to linking adjectives to nouns, 的 (de) can also be used to link a whole phrase to a noun, making the already useful 的 (de) even more useful. In English this is often achieved with \"who\" or \"that.\" Here a phrase means Verb + (Object)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-081-modifying-nouns-with-phrase-de-001,
        srs-inst:sent-gp-a2-081-modifying-nouns-with-phrase-de-002,
        srs-inst:sent-gp-a2-081-modifying-nouns-with-phrase-de-003,
        srs-inst:sent-gp-a2-081-modifying-nouns-with-phrase-de-004,
        srs-inst:sent-gp-a2-081-modifying-nouns-with-phrase-de-005,
        srs-inst:sent-gp-a2-081-modifying-nouns-with-phrase-de-006,
        srs-inst:sent-gp-a2-081-modifying-nouns-with-phrase-de-007,
        srs-inst:sent-gp-a2-081-modifying-nouns-with-phrase-de-008,
        srs-inst:sent-gp-a2-081-modifying-nouns-with-phrase-de-009,
        srs-inst:sent-gp-a2-081-modifying-nouns-with-phrase-de-010 ;
    srs-kg:structure "Phrase + 的 + Noun" .

srs-inst:gp-a2-084-expressing-or-in-statements-with-huozhe a srs-kg:GrammarPoint ;
    rdfs:label "Expressing \"or\" in statements with \"huozhe\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "或者 (huòzhě) is used to connect choices or possibilities within a statement, similar to 'or' in English. It is used in declarative sentences, whereas 还是 (háishì) is used for 'or' in questions."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-084-expressing-or-in-statements-with-huozhe-001,
        srs-inst:sent-gp-a2-084-expressing-or-in-statements-with-huozhe-002,
        srs-inst:sent-gp-a2-084-expressing-or-in-statements-with-huozhe-003,
        srs-inst:sent-gp-a2-084-expressing-or-in-statements-with-huozhe-004,
        srs-inst:sent-gp-a2-084-expressing-or-in-statements-with-huozhe-005,
        srs-inst:sent-gp-a2-084-expressing-or-in-statements-with-huozhe-006,
        srs-inst:sent-gp-a2-084-expressing-or-in-statements-with-huozhe-007,
        srs-inst:sent-gp-a2-084-expressing-or-in-statements-with-huozhe-008,
        srs-inst:sent-gp-a2-084-expressing-or-in-statements-with-huozhe-009,
        srs-inst:sent-gp-a2-084-expressing-or-in-statements-with-huozhe-010 ;
    srs-kg:structure "Possibility 1 + 或者 + Possibility 2" .

srs-inst:gp-a2-085-the-filler-word-neige a srs-kg:GrammarPoint ;
    rdfs:label "The filler word \"neige\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "那个 (nèige) is used as a filler word in Chinese, similar to 'um' or 'uh' in English. It can be inserted into sentences wherever a speaker needs to pause to think or search for a word."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-085-the-filler-word-neige-001,
        srs-inst:sent-gp-a2-085-the-filler-word-neige-002,
        srs-inst:sent-gp-a2-085-the-filler-word-neige-003,
        srs-inst:sent-gp-a2-085-the-filler-word-neige-004,
        srs-inst:sent-gp-a2-085-the-filler-word-neige-005,
        srs-inst:sent-gp-a2-085-the-filler-word-neige-006,
        srs-inst:sent-gp-a2-085-the-filler-word-neige-007,
        srs-inst:sent-gp-a2-085-the-filler-word-neige-008,
        srs-inst:sent-gp-a2-085-the-filler-word-neige-009,
        srs-inst:sent-gp-a2-085-the-filler-word-neige-010 ;
    srs-kg:structure "(那个……) + [anything] + (那个……)" .

srs-inst:gp-a2-086-two-words-for-but-keshi-and-danshi a srs-kg:GrammarPoint ;
    rdfs:label "Two words for \"but\": \"keshi\" and \"danshi\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "There are two main words for 'but' in Chinese: 可是 (kěshì) and 但是 (dànshì). They are largely interchangeable and used to introduce a statement that contrasts with the previous one. 但是 (dànshì) is considered slightly more formal, while 可是 (kěshì) is more informal and can have a stronger tone."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-086-two-words-for-but-keshi-and-danshi-001,
        srs-inst:sent-gp-a2-086-two-words-for-but-keshi-and-danshi-002,
        srs-inst:sent-gp-a2-086-two-words-for-but-keshi-and-danshi-003,
        srs-inst:sent-gp-a2-086-two-words-for-but-keshi-and-danshi-004,
        srs-inst:sent-gp-a2-086-two-words-for-but-keshi-and-danshi-005,
        srs-inst:sent-gp-a2-086-two-words-for-but-keshi-and-danshi-006,
        srs-inst:sent-gp-a2-086-two-words-for-but-keshi-and-danshi-007,
        srs-inst:sent-gp-a2-086-two-words-for-but-keshi-and-danshi-008,
        srs-inst:sent-gp-a2-086-two-words-for-but-keshi-and-danshi-009,
        srs-inst:sent-gp-a2-086-two-words-for-but-keshi-and-danshi-010 ;
    srs-kg:structure "Statement, 可是 / 但是 + [contrary statement]" .

srs-inst:gp-a2-088-before-in-general-with-yiqian a srs-kg:GrammarPoint ;
    rdfs:label "\"Before\" in general with \"yiqian\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "以前 (yǐqián) is used to talk about actions or states that occurred at an unspecified time in the past. It can be placed either at the beginning of a sentence or after the subject."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-088-before-in-general-with-yiqian-001,
        srs-inst:sent-gp-a2-088-before-in-general-with-yiqian-002,
        srs-inst:sent-gp-a2-088-before-in-general-with-yiqian-003,
        srs-inst:sent-gp-a2-088-before-in-general-with-yiqian-004,
        srs-inst:sent-gp-a2-088-before-in-general-with-yiqian-005,
        srs-inst:sent-gp-a2-088-before-in-general-with-yiqian-006,
        srs-inst:sent-gp-a2-088-before-in-general-with-yiqian-007,
        srs-inst:sent-gp-a2-088-before-in-general-with-yiqian-008,
        srs-inst:sent-gp-a2-088-before-in-general-with-yiqian-009,
        srs-inst:sent-gp-a2-088-before-in-general-with-yiqian-010 ;
    srs-kg:structure "以前, Subj. + Verb + Obj.  OR  Subj. + 以前 + Verb + Obj." .

srs-inst:gp-a2-089-just-now-with-gangcai a srs-kg:GrammarPoint ;
    rdfs:label "\"Just now\" with \"gangcai\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "刚才 (gāngcái) is a time noun used to indicate that an action occurred very recently, equivalent to 'just now' or 'a moment ago'. It can be placed before the subject or after the subject (before the verb)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-089-just-now-with-gangcai-001,
        srs-inst:sent-gp-a2-089-just-now-with-gangcai-002,
        srs-inst:sent-gp-a2-089-just-now-with-gangcai-003,
        srs-inst:sent-gp-a2-089-just-now-with-gangcai-004,
        srs-inst:sent-gp-a2-089-just-now-with-gangcai-005,
        srs-inst:sent-gp-a2-089-just-now-with-gangcai-006,
        srs-inst:sent-gp-a2-089-just-now-with-gangcai-007,
        srs-inst:sent-gp-a2-089-just-now-with-gangcai-008,
        srs-inst:sent-gp-a2-089-just-now-with-gangcai-009,
        srs-inst:sent-gp-a2-089-just-now-with-gangcai-010 ;
    srs-kg:structure "(Subj.) + 刚才 + Verb Phrase  OR  刚才 + (Subj.) + Verb Phrase" .

srs-inst:gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou a srs-kg:GrammarPoint ;
    rdfs:label "When with 的时候 (de shíhou)"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "Used to indicate the time when an action or state occurs, similar to 'when' or 'while' in English. The phrase before 的时候 can be a verb phrase, an adjective phrase, or a clause describing a situation."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-001,
        srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-002,
        srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-003,
        srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-004,
        srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-005,
        srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-006,
        srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-007,
        srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-008,
        srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-009,
        srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-010 ;
    srs-kg:structure "Phrase + 的时候 (de shíhou), ..." .

srs-inst:gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u a srs-kg:GrammarPoint ;
    rdfs:label "After a specific time with 以后 (yǐhòu)"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "以后 (yǐhòu) is used to describe events that happen after a specific time or action. The time can be a specific date, time, or an event/action."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-001,
        srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-002,
        srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-003,
        srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-004,
        srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-005,
        srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-006,
        srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-007,
        srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-008,
        srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-009,
        srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-010 ;
    srs-kg:structure "Time + 以后, Subj. + Verb + Obj. / Verb + 以后, Subj. + Verb + Obj." .

srs-inst:gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n a srs-kg:GrammarPoint ;
    rdfs:label "Before a specific time with 以前 (yǐqián)"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "以前 (yǐqián) is used to talk about things that happened before a specific time or action. The time can be a specific point in time or an event."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-001,
        srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-002,
        srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-003,
        srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-004,
        srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-005,
        srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-006,
        srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-007,
        srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-008,
        srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-009,
        srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-010 ;
    srs-kg:structure "Time / Verb + 以前, Subj. + Verb + Obj." .

srs-inst:gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u a srs-kg:GrammarPoint ;
    rdfs:label "In the future in general with 以后 (yǐhòu)"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "以后 (yǐhòu) can be used to talk about events happening at some unspecified time in the future, similar to 'in the future' or 'later on'. It can be placed either at the beginning of the sentence or after the subject."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-001,
        srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-002,
        srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-003,
        srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-004,
        srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-005,
        srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-006,
        srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-007,
        srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-008,
        srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-009,
        srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-010 ;
    srs-kg:structure "以后 + Subj. + Verb + Obj. / Subj. + 以后 + Verb + Obj." .

srs-inst:gp-a2-095-time-words-and-word-order a srs-kg:GrammarPoint ;
    rdfs:label "Time words and word order"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "In Chinese, time words (like 'yesterday', 'next week') must be placed before the verb. They can appear either at the beginning of the sentence before the subject, or directly after the subject."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-095-time-words-and-word-order-001,
        srs-inst:sent-gp-a2-095-time-words-and-word-order-002,
        srs-inst:sent-gp-a2-095-time-words-and-word-order-003,
        srs-inst:sent-gp-a2-095-time-words-and-word-order-004,
        srs-inst:sent-gp-a2-095-time-words-and-word-order-005,
        srs-inst:sent-gp-a2-095-time-words-and-word-order-006,
        srs-inst:sent-gp-a2-095-time-words-and-word-order-007,
        srs-inst:sent-gp-a2-095-time-words-and-word-order-008,
        srs-inst:sent-gp-a2-095-time-words-and-word-order-009,
        srs-inst:sent-gp-a2-095-time-words-and-word-order-010 ;
    srs-kg:structure "Time + Subj. + Verb + Obj. / Subj. + Time + Verb + Obj." .

srs-inst:gp-a2-096-approximating-with-sequential-numbers a srs-kg:GrammarPoint ;
    rdfs:label "Approximating with sequential numbers"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "To express an approximate number, you can simply state two sequential numbers in a row. This is similar to saying 'x or y' or 'about x' in English."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-096-approximating-with-sequential-numbers-001,
        srs-inst:sent-gp-a2-096-approximating-with-sequential-numbers-002,
        srs-inst:sent-gp-a2-096-approximating-with-sequential-numbers-003,
        srs-inst:sent-gp-a2-096-approximating-with-sequential-numbers-004,
        srs-inst:sent-gp-a2-096-approximating-with-sequential-numbers-005,
        srs-inst:sent-gp-a2-096-approximating-with-sequential-numbers-006,
        srs-inst:sent-gp-a2-096-approximating-with-sequential-numbers-007,
        srs-inst:sent-gp-a2-096-approximating-with-sequential-numbers-008,
        srs-inst:sent-gp-a2-096-approximating-with-sequential-numbers-009,
        srs-inst:sent-gp-a2-096-approximating-with-sequential-numbers-010 ;
    srs-kg:structure "Number + (Number+1)" .

srs-inst:gp-a2-097-big-numbers-in-chinese a srs-kg:GrammarPoint ;
    rdfs:label "Big numbers in Chinese"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "Chinese breaks down large numbers differently from English. Instead of grouping by thousands, Chinese groups numbers by tens of thousands (万, wàn). For numbers larger than one hundred million, the unit 亿 (yì) is used."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-097-big-numbers-in-chinese-001,
        srs-inst:sent-gp-a2-097-big-numbers-in-chinese-002,
        srs-inst:sent-gp-a2-097-big-numbers-in-chinese-003,
        srs-inst:sent-gp-a2-097-big-numbers-in-chinese-004,
        srs-inst:sent-gp-a2-097-big-numbers-in-chinese-005,
        srs-inst:sent-gp-a2-097-big-numbers-in-chinese-006,
        srs-inst:sent-gp-a2-097-big-numbers-in-chinese-007,
        srs-inst:sent-gp-a2-097-big-numbers-in-chinese-008,
        srs-inst:sent-gp-a2-097-big-numbers-in-chinese-009,
        srs-inst:sent-gp-a2-097-big-numbers-in-chinese-010 ;
    srs-kg:structure "Numbers are grouped in units of four digits, using 万 (wàn) for ten thousand and 亿 (yì) for a hundred million." .

srs-inst:gp-a2-104-change-of-state-with-le a srs-kg:GrammarPoint ;
    rdfs:label "Change of state with \"le\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "This use of 了 (le) is about indicating a change of state (了2). In other words, there is now a new situation, or there is about to be a new situation. When used in this way, 了(le) is placed at the end of the sentence to show that the whole statement describes a new situation."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-104-change-of-state-with-le-001,
        srs-inst:sent-gp-a2-104-change-of-state-with-le-002,
        srs-inst:sent-gp-a2-104-change-of-state-with-le-003,
        srs-inst:sent-gp-a2-104-change-of-state-with-le-004,
        srs-inst:sent-gp-a2-104-change-of-state-with-le-005,
        srs-inst:sent-gp-a2-104-change-of-state-with-le-006,
        srs-inst:sent-gp-a2-104-change-of-state-with-le-007,
        srs-inst:sent-gp-a2-104-change-of-state-with-le-008,
        srs-inst:sent-gp-a2-104-change-of-state-with-le-009,
        srs-inst:sent-gp-a2-104-change-of-state-with-le-010 ;
    srs-kg:structure "[New Situation] + 了" .

srs-inst:gp-a2-107-expressing-not-anymore-with-le a srs-kg:GrammarPoint ;
    rdfs:label "Expressing \"not anymore\" with \"le\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "In a negative sentence, the sentence-final 了 (le) can take on the meaning of '(not) anymore' or 'no longer.' The word 已经 (yǐjīng), which means 'already,' may or may not accompany it."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-107-expressing-not-anymore-with-le-001,
        srs-inst:sent-gp-a2-107-expressing-not-anymore-with-le-002,
        srs-inst:sent-gp-a2-107-expressing-not-anymore-with-le-003,
        srs-inst:sent-gp-a2-107-expressing-not-anymore-with-le-004,
        srs-inst:sent-gp-a2-107-expressing-not-anymore-with-le-005,
        srs-inst:sent-gp-a2-107-expressing-not-anymore-with-le-006,
        srs-inst:sent-gp-a2-107-expressing-not-anymore-with-le-007,
        srs-inst:sent-gp-a2-107-expressing-not-anymore-with-le-008,
        srs-inst:sent-gp-a2-107-expressing-not-anymore-with-le-009,
        srs-inst:sent-gp-a2-107-expressing-not-anymore-with-le-010 ;
    srs-kg:structure "(已经 +) 不 / 没(有) + [Verb Phrase] + 了" .

srs-inst:gp-a2-108-expressing-now-with-le a srs-kg:GrammarPoint ;
    rdfs:label "Expressing \"now\" with \"le\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "In many common expressions, 了 (le) is used in place of the word for 'now' (现在 xiànzài). This pattern is a specific application of the 'change of state' usage of 了."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-108-expressing-now-with-le-001,
        srs-inst:sent-gp-a2-108-expressing-now-with-le-002,
        srs-inst:sent-gp-a2-108-expressing-now-with-le-003,
        srs-inst:sent-gp-a2-108-expressing-now-with-le-004,
        srs-inst:sent-gp-a2-108-expressing-now-with-le-005,
        srs-inst:sent-gp-a2-108-expressing-now-with-le-006,
        srs-inst:sent-gp-a2-108-expressing-now-with-le-007,
        srs-inst:sent-gp-a2-108-expressing-now-with-le-008,
        srs-inst:sent-gp-a2-108-expressing-now-with-le-009,
        srs-inst:sent-gp-a2-108-expressing-now-with-le-010 ;
    srs-kg:structure "[New Situation] + 了" .

srs-inst:gp-a2-109-expressing-completion-with-le a srs-kg:GrammarPoint ;
    rdfs:label "Expressing completion with \"le\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "One of the most common uses of the particle 了 (le) is to express the completion of an action (perfective aspect). This is about whether the action is complete in a certain time frame, not necessarily that it happened in the past. To indicate completeness, 了 (le) goes directly after the verb."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-109-expressing-completion-with-le-001,
        srs-inst:sent-gp-a2-109-expressing-completion-with-le-002,
        srs-inst:sent-gp-a2-109-expressing-completion-with-le-003,
        srs-inst:sent-gp-a2-109-expressing-completion-with-le-004,
        srs-inst:sent-gp-a2-109-expressing-completion-with-le-005,
        srs-inst:sent-gp-a2-109-expressing-completion-with-le-006,
        srs-inst:sent-gp-a2-109-expressing-completion-with-le-007,
        srs-inst:sent-gp-a2-109-expressing-completion-with-le-008,
        srs-inst:sent-gp-a2-109-expressing-completion-with-le-009,
        srs-inst:sent-gp-a2-109-expressing-completion-with-le-010 ;
    srs-kg:structure "Subj. + Verb + 了 + Obj." .

srs-inst:gp-a2-113-softening-speech-with-ba a srs-kg:GrammarPoint ;
    rdfs:label "Softening speech with 'ba'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The particle 吧 (ba) can be used to soften the feel of a sentence. This could be to make it more polite, gentler and less forceful, or to turn a command into a suggestion."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-113-softening-speech-with-ba-001,
        srs-inst:sent-gp-a2-113-softening-speech-with-ba-002,
        srs-inst:sent-gp-a2-113-softening-speech-with-ba-003,
        srs-inst:sent-gp-a2-113-softening-speech-with-ba-004,
        srs-inst:sent-gp-a2-113-softening-speech-with-ba-005,
        srs-inst:sent-gp-a2-113-softening-speech-with-ba-006,
        srs-inst:sent-gp-a2-113-softening-speech-with-ba-007,
        srs-inst:sent-gp-a2-113-softening-speech-with-ba-008,
        srs-inst:sent-gp-a2-113-softening-speech-with-ba-009,
        srs-inst:sent-gp-a2-113-softening-speech-with-ba-010 ;
    srs-kg:structure "Statement + 吧" .

srs-inst:gp-a2-120-expressing-from-to-with-cong-dao a srs-kg:GrammarPoint ;
    rdfs:label "Expressing 'from… to…' with 'cong… dao…'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "从... 到... (cóng... dào...) is used in the same way as 'from... to...' in English, and can be used to specify a range for both times and places."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-120-expressing-from-to-with-cong-dao-001,
        srs-inst:sent-gp-a2-120-expressing-from-to-with-cong-dao-002,
        srs-inst:sent-gp-a2-120-expressing-from-to-with-cong-dao-003,
        srs-inst:sent-gp-a2-120-expressing-from-to-with-cong-dao-004,
        srs-inst:sent-gp-a2-120-expressing-from-to-with-cong-dao-005,
        srs-inst:sent-gp-a2-120-expressing-from-to-with-cong-dao-006,
        srs-inst:sent-gp-a2-120-expressing-from-to-with-cong-dao-007,
        srs-inst:sent-gp-a2-120-expressing-from-to-with-cong-dao-008,
        srs-inst:sent-gp-a2-120-expressing-from-to-with-cong-dao-009,
        srs-inst:sent-gp-a2-120-expressing-from-to-with-cong-dao-010 ;
    srs-kg:structure "从 + Time 1 / Place 1 + 到 + Time 2 / Place 2" .

srs-inst:gp-a2-122-directional-verbs-lai-and-qu a srs-kg:GrammarPoint ;
    rdfs:label "Directional verbs 'lai' and 'qu'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "来 (lái) and 去 (qù) are directional verbs used from the speaker's perspective. 来 (lái) means 'come' and indicates movement towards the speaker, while 去 (qù) means 'go' and indicates movement away from the speaker."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-122-directional-verbs-lai-and-qu-001,
        srs-inst:sent-gp-a2-122-directional-verbs-lai-and-qu-002,
        srs-inst:sent-gp-a2-122-directional-verbs-lai-and-qu-003,
        srs-inst:sent-gp-a2-122-directional-verbs-lai-and-qu-004,
        srs-inst:sent-gp-a2-122-directional-verbs-lai-and-qu-005,
        srs-inst:sent-gp-a2-122-directional-verbs-lai-and-qu-006,
        srs-inst:sent-gp-a2-122-directional-verbs-lai-and-qu-007,
        srs-inst:sent-gp-a2-122-directional-verbs-lai-and-qu-008,
        srs-inst:sent-gp-a2-122-directional-verbs-lai-and-qu-009,
        srs-inst:sent-gp-a2-122-directional-verbs-lai-and-qu-010 ;
    srs-kg:structure "来 / 去 + Place" .

srs-inst:gp-a2-124-expressing-should-with-yinggai a srs-kg:GrammarPoint ;
    rdfs:label "Expressing 'should' with 'yinggai'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "应该 (yīnggāi) is an auxiliary verb that translates to 'should'. To express 'should not', the negative adverb 不 (bù) is placed before 应该."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-124-expressing-should-with-yinggai-001,
        srs-inst:sent-gp-a2-124-expressing-should-with-yinggai-002,
        srs-inst:sent-gp-a2-124-expressing-should-with-yinggai-003,
        srs-inst:sent-gp-a2-124-expressing-should-with-yinggai-004,
        srs-inst:sent-gp-a2-124-expressing-should-with-yinggai-005,
        srs-inst:sent-gp-a2-124-expressing-should-with-yinggai-006,
        srs-inst:sent-gp-a2-124-expressing-should-with-yinggai-007,
        srs-inst:sent-gp-a2-124-expressing-should-with-yinggai-008,
        srs-inst:sent-gp-a2-124-expressing-should-with-yinggai-009,
        srs-inst:sent-gp-a2-124-expressing-should-with-yinggai-010 ;
    srs-kg:structure "Subj. + (不)应该 + Verb + Obj." .

srs-inst:gp-a2-126-expressing-would-like-to-with-xiang a srs-kg:GrammarPoint ;
    rdfs:label "Expressing \"would like to\" with \"xiang\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The verb 想 (xiǎng) can be used to express 'would like to.' In this case it's an auxiliary verb. To negate it, place 不 (bù) before 想 (xiǎng). Although similar to 要 (yào), 想 (xiǎng) provides a more tactful option to articulate a desire."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-126-expressing-would-like-to-with-xiang-001,
        srs-inst:sent-gp-a2-126-expressing-would-like-to-with-xiang-002,
        srs-inst:sent-gp-a2-126-expressing-would-like-to-with-xiang-003,
        srs-inst:sent-gp-a2-126-expressing-would-like-to-with-xiang-004,
        srs-inst:sent-gp-a2-126-expressing-would-like-to-with-xiang-005,
        srs-inst:sent-gp-a2-126-expressing-would-like-to-with-xiang-006,
        srs-inst:sent-gp-a2-126-expressing-would-like-to-with-xiang-007,
        srs-inst:sent-gp-a2-126-expressing-would-like-to-with-xiang-008,
        srs-inst:sent-gp-a2-126-expressing-would-like-to-with-xiang-009,
        srs-inst:sent-gp-a2-126-expressing-would-like-to-with-xiang-010 ;
    srs-kg:structure """Affirmative: Subj. + 想 + Verb + Obj.
Negative: Subj. + 不 + 想 + Verb + Obj.""" .

srs-inst:gp-a2-127-actions-in-a-row a srs-kg:GrammarPoint ;
    rdfs:label "Actions in a row"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "In Chinese, it's very easy to describe two actions in a row. Simply place one verb phrase after another. No connecting word is needed. A common mistake in the early stages of learning Chinese is to try and link verbs with 和 (hé). This is incorrect - 和 (hé) can only link nouns. Just place one verb after another."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-127-actions-in-a-row-001,
        srs-inst:sent-gp-a2-127-actions-in-a-row-002,
        srs-inst:sent-gp-a2-127-actions-in-a-row-003,
        srs-inst:sent-gp-a2-127-actions-in-a-row-004,
        srs-inst:sent-gp-a2-127-actions-in-a-row-005,
        srs-inst:sent-gp-a2-127-actions-in-a-row-006,
        srs-inst:sent-gp-a2-127-actions-in-a-row-007,
        srs-inst:sent-gp-a2-127-actions-in-a-row-008,
        srs-inst:sent-gp-a2-127-actions-in-a-row-009,
        srs-inst:sent-gp-a2-127-actions-in-a-row-010 ;
    srs-kg:structure "Subj. + [Verb Phrase 1] + [Verb Phrase 2]" .

srs-inst:gp-a2-128-expressing-difficult-with-nan a srs-kg:GrammarPoint ;
    rdfs:label "Expressing \"difficult\" with \"nan\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "难 (nán) is an adjective that means 'difficult.' It can be used when something is 'hard to do' or 'bad to do' (as in a bad experience). It can be attached to general verbs to indicate that something is hard to do. It can also be attached to 'sense verbs' (e.g., look, taste, smell) to indicate a bad sensory experience."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-128-expressing-difficult-with-nan-001,
        srs-inst:sent-gp-a2-128-expressing-difficult-with-nan-002,
        srs-inst:sent-gp-a2-128-expressing-difficult-with-nan-003,
        srs-inst:sent-gp-a2-128-expressing-difficult-with-nan-004,
        srs-inst:sent-gp-a2-128-expressing-difficult-with-nan-005,
        srs-inst:sent-gp-a2-128-expressing-difficult-with-nan-006,
        srs-inst:sent-gp-a2-128-expressing-difficult-with-nan-007,
        srs-inst:sent-gp-a2-128-expressing-difficult-with-nan-008,
        srs-inst:sent-gp-a2-128-expressing-difficult-with-nan-009,
        srs-inst:sent-gp-a2-128-expressing-difficult-with-nan-010 ;
    srs-kg:structure """With general verbs: Subj. + (很) 难 + Verb
With sense verbs: Subj. + (很) 难 + [Sense Verb]""" .

srs-inst:gp-a2-129-expressing-never-with-conglai a srs-kg:GrammarPoint ;
    rdfs:label "Expressing \"never\" with \"conglai\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "从来 (cónglái) is usually used to express that you 'never do something' (as a habit or rule), or that you 'have never done something' (as a life experience). It can be shortened to 从 (cóng) in casual speech. Use 从来不 to express a habit. Use 从来没有...过 to express a lack of past experience."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-129-expressing-never-with-conglai-001,
        srs-inst:sent-gp-a2-129-expressing-never-with-conglai-002,
        srs-inst:sent-gp-a2-129-expressing-never-with-conglai-003,
        srs-inst:sent-gp-a2-129-expressing-never-with-conglai-004,
        srs-inst:sent-gp-a2-129-expressing-never-with-conglai-005,
        srs-inst:sent-gp-a2-129-expressing-never-with-conglai-006,
        srs-inst:sent-gp-a2-129-expressing-never-with-conglai-007,
        srs-inst:sent-gp-a2-129-expressing-never-with-conglai-008,
        srs-inst:sent-gp-a2-129-expressing-never-with-conglai-009,
        srs-inst:sent-gp-a2-129-expressing-never-with-conglai-010 ;
    srs-kg:structure """To never do: Subj. + 从来 + 不 + [Verb Phrase]
To have never done: Subj. + 从来 + 没(有) + Verb + 过""" .

srs-inst:gp-a2-130-expressing-together-with-yiqi a srs-kg:GrammarPoint ;
    rdfs:label "Expressing \"together\" with \"yiqi\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "To express that an action is being done together with someone else, use 一起 (yīqǐ). The subject must be plural (e.g., 我们, a group of people, or two nouns linked with a conjunction like 和) because you can't do things 'together' alone."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-130-expressing-together-with-yiqi-001,
        srs-inst:sent-gp-a2-130-expressing-together-with-yiqi-002,
        srs-inst:sent-gp-a2-130-expressing-together-with-yiqi-003,
        srs-inst:sent-gp-a2-130-expressing-together-with-yiqi-004,
        srs-inst:sent-gp-a2-130-expressing-together-with-yiqi-005,
        srs-inst:sent-gp-a2-130-expressing-together-with-yiqi-006,
        srs-inst:sent-gp-a2-130-expressing-together-with-yiqi-007,
        srs-inst:sent-gp-a2-130-expressing-together-with-yiqi-008,
        srs-inst:sent-gp-a2-130-expressing-together-with-yiqi-009,
        srs-inst:sent-gp-a2-130-expressing-together-with-yiqi-010 ;
    srs-kg:structure "[Plural subj.] + 一起 + Verb + Obj." .

srs-inst:gp-a2-131-expressing-duration-with-le a srs-kg:GrammarPoint ;
    rdfs:label "Expressing duration with \"le\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "To express how long a completed action lasted, place 了 (le) after the verb, followed by the duration. To emphasize that the action is definitely completed and not ongoing, a time word (like 昨天) can be added to the sentence to place the event in the past."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-131-expressing-duration-with-le-001,
        srs-inst:sent-gp-a2-131-expressing-duration-with-le-002,
        srs-inst:sent-gp-a2-131-expressing-duration-with-le-003,
        srs-inst:sent-gp-a2-131-expressing-duration-with-le-004,
        srs-inst:sent-gp-a2-131-expressing-duration-with-le-005,
        srs-inst:sent-gp-a2-131-expressing-duration-with-le-006,
        srs-inst:sent-gp-a2-131-expressing-duration-with-le-007,
        srs-inst:sent-gp-a2-131-expressing-duration-with-le-008,
        srs-inst:sent-gp-a2-131-expressing-duration-with-le-009,
        srs-inst:sent-gp-a2-131-expressing-duration-with-le-010 ;
    srs-kg:structure """Basic: Subj. + Verb + 了 + Duration + Obj.
Definitely completed: Subj. + [Time Word] + Verb + 了 + Duration + Obj.""" .

srs-inst:gp-a2-133-inability-with-mei-banfa a srs-kg:GrammarPoint ;
    rdfs:label "Inability with 'mei banfa'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "To express that something is impossible or there is no way to do something, you can use the phrase 没办法 (méi bànfǎ) before the verb."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-133-inability-with-mei-banfa-001,
        srs-inst:sent-gp-a2-133-inability-with-mei-banfa-002,
        srs-inst:sent-gp-a2-133-inability-with-mei-banfa-003,
        srs-inst:sent-gp-a2-133-inability-with-mei-banfa-004,
        srs-inst:sent-gp-a2-133-inability-with-mei-banfa-005,
        srs-inst:sent-gp-a2-133-inability-with-mei-banfa-006,
        srs-inst:sent-gp-a2-133-inability-with-mei-banfa-007,
        srs-inst:sent-gp-a2-133-inability-with-mei-banfa-008,
        srs-inst:sent-gp-a2-133-inability-with-mei-banfa-009,
        srs-inst:sent-gp-a2-133-inability-with-mei-banfa-010 ;
    srs-kg:structure "Subj. + 没办法 + Verb + Obj." .

srs-inst:gp-a2-134-indicating-location-with-zai-before-verbs a srs-kg:GrammarPoint ;
    rdfs:label "Indicating location with 'zai' before verbs"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "To indicate the location where a verb takes place, 在 (zài) followed by a location is placed before the verb. This word order is different from English, where the location typically comes after the verb."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-134-indicating-location-with-zai-before-verbs-001,
        srs-inst:sent-gp-a2-134-indicating-location-with-zai-before-verbs-002,
        srs-inst:sent-gp-a2-134-indicating-location-with-zai-before-verbs-003,
        srs-inst:sent-gp-a2-134-indicating-location-with-zai-before-verbs-004,
        srs-inst:sent-gp-a2-134-indicating-location-with-zai-before-verbs-005,
        srs-inst:sent-gp-a2-134-indicating-location-with-zai-before-verbs-006,
        srs-inst:sent-gp-a2-134-indicating-location-with-zai-before-verbs-007,
        srs-inst:sent-gp-a2-134-indicating-location-with-zai-before-verbs-008,
        srs-inst:sent-gp-a2-134-indicating-location-with-zai-before-verbs-009,
        srs-inst:sent-gp-a2-134-indicating-location-with-zai-before-verbs-010 ;
    srs-kg:structure "Subj. + 在 + Place + Verb + Obj." .

srs-inst:gp-a2-136-special-cases-of-zai-following-verbs a srs-kg:GrammarPoint ;
    rdfs:label "Special cases of 'zai' following verbs"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "While 在 (zài) usually comes before the verb to indicate location, it is placed after certain special verbs that imply movement or location, such as 住 (zhù), 放 (fàng), 坐 (zuò), 站 (zhàn), 走 (zǒu), and 待 (dāi)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-136-special-cases-of-zai-following-verbs-001,
        srs-inst:sent-gp-a2-136-special-cases-of-zai-following-verbs-002,
        srs-inst:sent-gp-a2-136-special-cases-of-zai-following-verbs-003,
        srs-inst:sent-gp-a2-136-special-cases-of-zai-following-verbs-004,
        srs-inst:sent-gp-a2-136-special-cases-of-zai-following-verbs-005,
        srs-inst:sent-gp-a2-136-special-cases-of-zai-following-verbs-006,
        srs-inst:sent-gp-a2-136-special-cases-of-zai-following-verbs-007,
        srs-inst:sent-gp-a2-136-special-cases-of-zai-following-verbs-008,
        srs-inst:sent-gp-a2-136-special-cases-of-zai-following-verbs-009,
        srs-inst:sent-gp-a2-136-special-cases-of-zai-following-verbs-010 ;
    srs-kg:structure "Subj. + [Special Verb] + 在 + Location" .

srs-inst:gp-a2-138-using-dao-to-mean-to-go-to a srs-kg:GrammarPoint ;
    rdfs:label "Using 'dao' to mean 'to go to'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The verb 到 (dào) is used to talk about going to or arriving at a specific place, emphasizing the destination. If an action is performed at the destination, you can add a verb phrase after the place, with the meaning of 'going to the place to do something'."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-138-using-dao-to-mean-to-go-to-001,
        srs-inst:sent-gp-a2-138-using-dao-to-mean-to-go-to-002,
        srs-inst:sent-gp-a2-138-using-dao-to-mean-to-go-to-003,
        srs-inst:sent-gp-a2-138-using-dao-to-mean-to-go-to-004,
        srs-inst:sent-gp-a2-138-using-dao-to-mean-to-go-to-005,
        srs-inst:sent-gp-a2-138-using-dao-to-mean-to-go-to-006,
        srs-inst:sent-gp-a2-138-using-dao-to-mean-to-go-to-007,
        srs-inst:sent-gp-a2-138-using-dao-to-mean-to-go-to-008,
        srs-inst:sent-gp-a2-138-using-dao-to-mean-to-go-to-009,
        srs-inst:sent-gp-a2-138-using-dao-to-mean-to-go-to-010 ;
    srs-kg:structure "Subj. + 到 + Place (+ Verb Phrase)" .

srs-inst:gp-a1-033-using-the-verb-jiao a srs-kg:GrammarPoint ;
    rdfs:label "Using the verb \"jiao\""@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The verb 叫 (jiào) is used to indicate what someone or something is called, or what someone or something's name is. Its usage can seem a little weird to beginners, so it gets its own grammar point. The verb 叫 (jiào) means both \"to call\" and \"to be called.\" It's an easy way to give names, using the following structure: Subj. + 叫 + [Name]. This can be used to give your full name or just your first name. You can also ask people their names using 叫 (jiào): 你 叫 什么 名字 ？"@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-033-using-the-verb-jiao-001,
        srs-inst:sent-gp-a1-033-using-the-verb-jiao-002,
        srs-inst:sent-gp-a1-033-using-the-verb-jiao-003,
        srs-inst:sent-gp-a1-033-using-the-verb-jiao-004,
        srs-inst:sent-gp-a1-033-using-the-verb-jiao-005,
        srs-inst:sent-gp-a1-033-using-the-verb-jiao-006,
        srs-inst:sent-gp-a1-033-using-the-verb-jiao-007,
        srs-inst:sent-gp-a1-033-using-the-verb-jiao-008,
        srs-inst:sent-gp-a1-033-using-the-verb-jiao-009,
        srs-inst:sent-gp-a1-033-using-the-verb-jiao-010,
        srs-inst:sent-gp-a1-033-using-the-verb-jiao-011 ;
    srs-kg:structure "Subj. + 叫 + [Name]" .

srs-inst:gp-a1-043-negation-of-past-actions-with-meiyou a srs-kg:GrammarPoint ;
    rdfs:label "Negation of past actions with 'meiyou'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "To negate an action in the past, use 没有 (méiyǒu) or its shorter form 没 (méi) before the verb. This is used to say that something 'didn't happen' or someone 'didn't do' something. Unlike negating present actions with 不 (bù), 没有 (méiyǒu) is specific to the past. It's important to remember not to use the completed action particle 了 (le) in a sentence with 没有 (méiyǒu)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-043-negation-of-past-actions-with-meiyou-001,
        srs-inst:sent-gp-a1-043-negation-of-past-actions-with-meiyou-002,
        srs-inst:sent-gp-a1-043-negation-of-past-actions-with-meiyou-003,
        srs-inst:sent-gp-a1-043-negation-of-past-actions-with-meiyou-004,
        srs-inst:sent-gp-a1-043-negation-of-past-actions-with-meiyou-005,
        srs-inst:sent-gp-a1-043-negation-of-past-actions-with-meiyou-006,
        srs-inst:sent-gp-a1-043-negation-of-past-actions-with-meiyou-007,
        srs-inst:sent-gp-a1-043-negation-of-past-actions-with-meiyou-008,
        srs-inst:sent-gp-a1-043-negation-of-past-actions-with-meiyou-009,
        srs-inst:sent-gp-a1-043-negation-of-past-actions-with-meiyou-010,
        srs-inst:sent-gp-a1-043-negation-of-past-actions-with-meiyou-011 ;
    srs-kg:structure "Subj. + 没有 / 没 + Verb" .

srs-inst:gp-a1-045-standard-negation-with-bu a srs-kg:GrammarPoint ;
    rdfs:label "Standard negation with 'bu'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The standard way to negate verbs and adjectives in the present or future is with 不 (bù). It is placed directly before the verb or adjective. This is used for habitual actions, current states, or future intentions. The only common verb that cannot be negated with 不 is 有 (yǒu), which uses 没有 (méiyǒu) instead."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-045-standard-negation-with-bu-001,
        srs-inst:sent-gp-a1-045-standard-negation-with-bu-002,
        srs-inst:sent-gp-a1-045-standard-negation-with-bu-003,
        srs-inst:sent-gp-a1-045-standard-negation-with-bu-004,
        srs-inst:sent-gp-a1-045-standard-negation-with-bu-005,
        srs-inst:sent-gp-a1-045-standard-negation-with-bu-006,
        srs-inst:sent-gp-a1-045-standard-negation-with-bu-007,
        srs-inst:sent-gp-a1-045-standard-negation-with-bu-008,
        srs-inst:sent-gp-a1-045-standard-negation-with-bu-009,
        srs-inst:sent-gp-a1-045-standard-negation-with-bu-010,
        srs-inst:sent-gp-a1-045-standard-negation-with-bu-011 ;
    srs-kg:structure "Subj. + 不 + Verb / Adj. (+ Obj.)" .

srs-inst:gp-a1-055-yes-no-questions-with-ma a srs-kg:GrammarPoint ;
    rdfs:label "Yes-no questions with 'ma'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The question particle 吗 (ma) is a simple way to form questions in Chinese. By placing 吗 (ma) on the end of a statement, you convert it into a yes/no question (questions that could be answered with yes or no in English). You could think of 吗 (ma) as being like a question mark you say out loud."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-055-yes-no-questions-with-ma-001,
        srs-inst:sent-gp-a1-055-yes-no-questions-with-ma-002,
        srs-inst:sent-gp-a1-055-yes-no-questions-with-ma-003,
        srs-inst:sent-gp-a1-055-yes-no-questions-with-ma-004,
        srs-inst:sent-gp-a1-055-yes-no-questions-with-ma-005,
        srs-inst:sent-gp-a1-055-yes-no-questions-with-ma-006,
        srs-inst:sent-gp-a1-055-yes-no-questions-with-ma-007,
        srs-inst:sent-gp-a1-055-yes-no-questions-with-ma-008,
        srs-inst:sent-gp-a1-055-yes-no-questions-with-ma-009,
        srs-inst:sent-gp-a1-055-yes-no-questions-with-ma-010,
        srs-inst:sent-gp-a1-055-yes-no-questions-with-ma-011 ;
    srs-kg:structure "[Statement] + 吗 ？" .

srs-inst:gp-a2-073-basic-comparisons-with-yiyang a srs-kg:GrammarPoint ;
    rdfs:label "Basic comparisons with 'yiyang'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "一样 (yīyàng) is used to express that two things are the same. It can be used alone to state that two things are alike, or with an adjective to specify that they share a quality to the same degree (e.g., 'as tall as')."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-001,
        srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-002,
        srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-003,
        srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-004,
        srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-005,
        srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-006,
        srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-007,
        srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-008,
        srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-009,
        srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-010,
        srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-011 ;
    srs-kg:structure "Noun 1 + 跟/和 + Noun 2 + 一样 (+ Adj.)" .

srs-inst:gp-a2-078-intensifying-with-duo a srs-kg:GrammarPoint ;
    rdfs:label "Intensifying with \"duo\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "One way to intensify a sentence is to make it an exclamation. To do this, you can use 多 (duō). 多 (duō) is used only for excited exclamations, whereas 很 (hěn) can be used in non-exclamatory sentences."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-078-intensifying-with-duo-001,
        srs-inst:sent-gp-a2-078-intensifying-with-duo-002,
        srs-inst:sent-gp-a2-078-intensifying-with-duo-003,
        srs-inst:sent-gp-a2-078-intensifying-with-duo-004,
        srs-inst:sent-gp-a2-078-intensifying-with-duo-005,
        srs-inst:sent-gp-a2-078-intensifying-with-duo-006,
        srs-inst:sent-gp-a2-078-intensifying-with-duo-007,
        srs-inst:sent-gp-a2-078-intensifying-with-duo-008,
        srs-inst:sent-gp-a2-078-intensifying-with-duo-009,
        srs-inst:sent-gp-a2-078-intensifying-with-duo-010,
        srs-inst:sent-gp-a2-078-intensifying-with-duo-011 ;
    srs-kg:structure "Subj. + 多 + Adj. !" .

srs-inst:gp-a1-015-measure-word-ge-%E4%B8%AA a srs-kg:GrammarPoint ;
    rdfs:label "Measure word 'ge' (个)"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "个 (gè) is the most common measure word in Chinese, used when specifying the quantity of a noun. The general structure is 'Number + 个 + Noun'. When the number is one, it can be omitted, resulting in the structure 'Verb + 个 + Noun', which is equivalent to 'a' or 'an' in English."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-015-measure-word-ge-%E4%B8%AA-001,
        srs-inst:sent-gp-a1-015-measure-word-ge-%E4%B8%AA-002,
        srs-inst:sent-gp-a1-015-measure-word-ge-%E4%B8%AA-003,
        srs-inst:sent-gp-a1-015-measure-word-ge-%E4%B8%AA-004,
        srs-inst:sent-gp-a1-015-measure-word-ge-%E4%B8%AA-005,
        srs-inst:sent-gp-a1-015-measure-word-ge-%E4%B8%AA-006,
        srs-inst:sent-gp-a1-015-measure-word-ge-%E4%B8%AA-007,
        srs-inst:sent-gp-a1-015-measure-word-ge-%E4%B8%AA-008,
        srs-inst:sent-gp-a1-015-measure-word-ge-%E4%B8%AA-009,
        srs-inst:sent-gp-a1-015-measure-word-ge-%E4%B8%AA-010,
        srs-inst:sent-gp-a1-015-measure-word-ge-%E4%B8%AA-011,
        srs-inst:sent-gp-a1-015-measure-word-ge-%E4%B8%AA-012 ;
    srs-kg:structure """Number + 个 + Noun
Verb + 个 + Noun""" .

srs-inst:gp-a1-027-asking-what-about-with-ne a srs-kg:GrammarPoint ;
    rdfs:label "Asking 'what about...?' with 'ne'"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The particle 呢 (ne) can be placed at the end of a noun or pronoun to ask a reciprocal question, meaning 'what about...?' or 'and you?'. It's a way to 'bounce back' a question that was just asked."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-027-asking-what-about-with-ne-001,
        srs-inst:sent-gp-a1-027-asking-what-about-with-ne-002,
        srs-inst:sent-gp-a1-027-asking-what-about-with-ne-003,
        srs-inst:sent-gp-a1-027-asking-what-about-with-ne-004,
        srs-inst:sent-gp-a1-027-asking-what-about-with-ne-005,
        srs-inst:sent-gp-a1-027-asking-what-about-with-ne-006,
        srs-inst:sent-gp-a1-027-asking-what-about-with-ne-007,
        srs-inst:sent-gp-a1-027-asking-what-about-with-ne-008,
        srs-inst:sent-gp-a1-027-asking-what-about-with-ne-009,
        srs-inst:sent-gp-a1-027-asking-what-about-with-ne-010,
        srs-inst:sent-gp-a1-027-asking-what-about-with-ne-011,
        srs-inst:sent-gp-a1-027-asking-what-about-with-ne-012 ;
    srs-kg:structure "Topic + 呢？" .

srs-inst:gp-a1-035-using-the-verb-xing a srs-kg:GrammarPoint ;
    rdfs:label "Using the verb \"xing\""@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The verb 姓 (xìng) literally means \"to be surnamed\" or \"to have the surname.\" It may seem awkward at first that there's a verb just for this, but you'll find that it's used quite often in Chinese. 姓 (xìng) is used most often to tell someone your own surname, or to ask the surname of someone else. You can also use 姓 (xìng) to ask people their surnames. You could do this quite directly by saying: 你 姓 什么 ? However, the formal way to ask has a set form: 您 贵 姓 ？"@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-035-using-the-verb-xing-001,
        srs-inst:sent-gp-a1-035-using-the-verb-xing-002,
        srs-inst:sent-gp-a1-035-using-the-verb-xing-003,
        srs-inst:sent-gp-a1-035-using-the-verb-xing-004,
        srs-inst:sent-gp-a1-035-using-the-verb-xing-005,
        srs-inst:sent-gp-a1-035-using-the-verb-xing-006,
        srs-inst:sent-gp-a1-035-using-the-verb-xing-007,
        srs-inst:sent-gp-a1-035-using-the-verb-xing-008,
        srs-inst:sent-gp-a1-035-using-the-verb-xing-009,
        srs-inst:sent-gp-a1-035-using-the-verb-xing-010,
        srs-inst:sent-gp-a1-035-using-the-verb-xing-011,
        srs-inst:sent-gp-a1-035-using-the-verb-xing-012 ;
    srs-kg:structure "Subj. + 姓 + [Surname]" .

srs-inst:gp-a1-050-simple-noun-adjective-sentences a srs-kg:GrammarPoint ;
    rdfs:label "Simple \"noun + adjective\" sentences"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "In Chinese, nouns are linked to adjectives using the adverb 很 (hěn). In this basic structure, 很 often acts as a linker, similar to the verb \"to be\" in English, and may not necessarily mean \"very\". It is a common mistake to use 是 (shì) to link nouns and adjectives; 很 (hěn) should be used instead. To explicitly express \"very,\" other adverbs like 非常 (fēicháng) can be used."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-050-simple-noun-adjective-sentences-001,
        srs-inst:sent-gp-a1-050-simple-noun-adjective-sentences-002,
        srs-inst:sent-gp-a1-050-simple-noun-adjective-sentences-003,
        srs-inst:sent-gp-a1-050-simple-noun-adjective-sentences-004,
        srs-inst:sent-gp-a1-050-simple-noun-adjective-sentences-005,
        srs-inst:sent-gp-a1-050-simple-noun-adjective-sentences-006,
        srs-inst:sent-gp-a1-050-simple-noun-adjective-sentences-007,
        srs-inst:sent-gp-a1-050-simple-noun-adjective-sentences-008,
        srs-inst:sent-gp-a1-050-simple-noun-adjective-sentences-009,
        srs-inst:sent-gp-a1-050-simple-noun-adjective-sentences-010,
        srs-inst:sent-gp-a1-050-simple-noun-adjective-sentences-011,
        srs-inst:sent-gp-a1-050-simple-noun-adjective-sentences-012 ;
    srs-kg:structure "Noun + 很 + Adj." .

srs-inst:gp-a2-087-using-gen-to-mean-with a srs-kg:GrammarPoint ;
    rdfs:label "Using \"gen\" to mean \"with\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The preposition 跟 (gēn) is used to express 'with'. The '跟 + Person' phrase must come before the verb. The adverb 一起 (yīqǐ), meaning 'together', is often used with 跟 (gēn) to emphasize the joint nature of the action. For most uses, 跟 (gēn) is interchangeable with 和 (hé)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-087-using-gen-to-mean-with-001,
        srs-inst:sent-gp-a2-087-using-gen-to-mean-with-002,
        srs-inst:sent-gp-a2-087-using-gen-to-mean-with-003,
        srs-inst:sent-gp-a2-087-using-gen-to-mean-with-004,
        srs-inst:sent-gp-a2-087-using-gen-to-mean-with-005,
        srs-inst:sent-gp-a2-087-using-gen-to-mean-with-006,
        srs-inst:sent-gp-a2-087-using-gen-to-mean-with-007,
        srs-inst:sent-gp-a2-087-using-gen-to-mean-with-008,
        srs-inst:sent-gp-a2-087-using-gen-to-mean-with-009,
        srs-inst:sent-gp-a2-087-using-gen-to-mean-with-010,
        srs-inst:sent-gp-a2-087-using-gen-to-mean-with-011,
        srs-inst:sent-gp-a2-087-using-gen-to-mean-with-012 ;
    srs-kg:structure "Subj. + 跟 + Person + (一起) + Verb + Obj." .

srs-inst:gp-a2-121-basic-comparisons-with-meiyou a srs-kg:GrammarPoint ;
    rdfs:label "Basic comparisons with 'meiyou'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The structure with 没有 (méiyǒu) is used to express that something is 'not as' [adjective] as something else. In this pattern, the first noun is less [adjective] than the second noun, making it the opposite of a comparison with 比 (bǐ)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-121-basic-comparisons-with-meiyou-001,
        srs-inst:sent-gp-a2-121-basic-comparisons-with-meiyou-002,
        srs-inst:sent-gp-a2-121-basic-comparisons-with-meiyou-003,
        srs-inst:sent-gp-a2-121-basic-comparisons-with-meiyou-004,
        srs-inst:sent-gp-a2-121-basic-comparisons-with-meiyou-005,
        srs-inst:sent-gp-a2-121-basic-comparisons-with-meiyou-006,
        srs-inst:sent-gp-a2-121-basic-comparisons-with-meiyou-007,
        srs-inst:sent-gp-a2-121-basic-comparisons-with-meiyou-008,
        srs-inst:sent-gp-a2-121-basic-comparisons-with-meiyou-009,
        srs-inst:sent-gp-a2-121-basic-comparisons-with-meiyou-010,
        srs-inst:sent-gp-a2-121-basic-comparisons-with-meiyou-011,
        srs-inst:sent-gp-a2-121-basic-comparisons-with-meiyou-012 ;
    srs-kg:structure "Noun 1 + 没有 + Noun 2 + Adj." .

srs-inst:gp-a1-052-placement-of-question-words a srs-kg:GrammarPoint ;
    rdfs:label "Placement of question words"@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "In Chinese, question words (e.g., 什么 what, 哪里 where, 谁 who, 什么时候 when, 为什么 why, 怎么 how) are placed in the position of the information being asked about. Unlike English, the word order of the sentence does not change from a statement to a question."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-052-placement-of-question-words-001,
        srs-inst:sent-gp-a1-052-placement-of-question-words-002,
        srs-inst:sent-gp-a1-052-placement-of-question-words-003,
        srs-inst:sent-gp-a1-052-placement-of-question-words-004,
        srs-inst:sent-gp-a1-052-placement-of-question-words-005,
        srs-inst:sent-gp-a1-052-placement-of-question-words-006,
        srs-inst:sent-gp-a1-052-placement-of-question-words-007,
        srs-inst:sent-gp-a1-052-placement-of-question-words-008,
        srs-inst:sent-gp-a1-052-placement-of-question-words-009,
        srs-inst:sent-gp-a1-052-placement-of-question-words-010,
        srs-inst:sent-gp-a1-052-placement-of-question-words-011,
        srs-inst:sent-gp-a1-052-placement-of-question-words-012,
        srs-inst:sent-gp-a1-052-placement-of-question-words-013 ;
    srs-kg:structure "Question word replaces the element of the sentence being asked about, maintaining statement word order." .

srs-inst:gp-a2-057-negative-adjectives-with-si-le a srs-kg:GrammarPoint ;
    rdfs:label "Negative adjectives with '-si le'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "In English, you might use the expression \"you scared me to death!\" In Chinese,  死了 (sǐle) is used similarly to intensify an adjective with an unpleasant connotation. The \"Subject\" part is optional. This structure is technically a kind of degree complement. Traditionally, -死了 (sǐle) is only for adjectives with negative connotations. In recent years, however, it's become quite popular to also use -死了 (sǐle) with positive adjectives."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-057-negative-adjectives-with-si-le-001,
        srs-inst:sent-gp-a2-057-negative-adjectives-with-si-le-002,
        srs-inst:sent-gp-a2-057-negative-adjectives-with-si-le-003,
        srs-inst:sent-gp-a2-057-negative-adjectives-with-si-le-004,
        srs-inst:sent-gp-a2-057-negative-adjectives-with-si-le-005,
        srs-inst:sent-gp-a2-057-negative-adjectives-with-si-le-006,
        srs-inst:sent-gp-a2-057-negative-adjectives-with-si-le-007,
        srs-inst:sent-gp-a2-057-negative-adjectives-with-si-le-008,
        srs-inst:sent-gp-a2-057-negative-adjectives-with-si-le-009,
        srs-inst:sent-gp-a2-057-negative-adjectives-with-si-le-010,
        srs-inst:sent-gp-a2-057-negative-adjectives-with-si-le-011,
        srs-inst:sent-gp-a2-057-negative-adjectives-with-si-le-012,
        srs-inst:sent-gp-a2-057-negative-adjectives-with-si-le-013 ;
    srs-kg:structure "Subj. + [Negative Adj.] + 死了" .

srs-inst:gp-a2-117-using-guo-with-le a srs-kg:GrammarPoint ;
    rdfs:label "Using 'guo' with 'le'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "When 过 (guò) is used together with 了 (le), it emphasizes that a routine action is 'already done'. This combination is often used for everyday behaviors to confirm their completion, implying they don't need to be done again. The word 已经 (yǐjīng) can be added to further emphasize 'already'."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-117-using-guo-with-le-001,
        srs-inst:sent-gp-a2-117-using-guo-with-le-002,
        srs-inst:sent-gp-a2-117-using-guo-with-le-003,
        srs-inst:sent-gp-a2-117-using-guo-with-le-004,
        srs-inst:sent-gp-a2-117-using-guo-with-le-005,
        srs-inst:sent-gp-a2-117-using-guo-with-le-006,
        srs-inst:sent-gp-a2-117-using-guo-with-le-007,
        srs-inst:sent-gp-a2-117-using-guo-with-le-008,
        srs-inst:sent-gp-a2-117-using-guo-with-le-009,
        srs-inst:sent-gp-a2-117-using-guo-with-le-010,
        srs-inst:sent-gp-a2-117-using-guo-with-le-011,
        srs-inst:sent-gp-a2-117-using-guo-with-le-012,
        srs-inst:sent-gp-a2-117-using-guo-with-le-013 ;
    srs-kg:structure "Verb + 过 + (Obj.) + 了" .

srs-inst:gp-a1-034-using-the-verb-qu a srs-kg:GrammarPoint ;
    rdfs:label "Using the verb \"qu\""@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "You can use 去 (qù) whenever you have somewhere to go. The verb 去 (qù) means \"to go,\" and is an easy way to talk about going to places. Notice that you don't need a word to express \"to.\" Instead of a place, 去 (qù) can also be followed by some sort of action. The structure then means \"go to do (something),\" and \"go and do (something).\""@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-034-using-the-verb-qu-001,
        srs-inst:sent-gp-a1-034-using-the-verb-qu-002,
        srs-inst:sent-gp-a1-034-using-the-verb-qu-003,
        srs-inst:sent-gp-a1-034-using-the-verb-qu-004,
        srs-inst:sent-gp-a1-034-using-the-verb-qu-005,
        srs-inst:sent-gp-a1-034-using-the-verb-qu-006,
        srs-inst:sent-gp-a1-034-using-the-verb-qu-007,
        srs-inst:sent-gp-a1-034-using-the-verb-qu-008,
        srs-inst:sent-gp-a1-034-using-the-verb-qu-009,
        srs-inst:sent-gp-a1-034-using-the-verb-qu-010,
        srs-inst:sent-gp-a1-034-using-the-verb-qu-011,
        srs-inst:sent-gp-a1-034-using-the-verb-qu-012,
        srs-inst:sent-gp-a1-034-using-the-verb-qu-013,
        srs-inst:sent-gp-a1-034-using-the-verb-qu-014 ;
    srs-kg:structure "Subj. + 去 + [Place] / Subj. + 去 + Verb" .

srs-inst:gp-a2-135-reduplication-of-verbs a srs-kg:GrammarPoint ;
    rdfs:label "Reduplication of verbs"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "In Chinese, verbs can be reduplicated to indicate that an action happens briefly or 'a little bit,' creating a casual tone. For single-syllable verbs, the pattern is either VV (e.g., 看看) or V一V (e.g., 看一看). For two-syllable verbs, the pattern is ABAB (e.g., 考虑考虑)."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-135-reduplication-of-verbs-001,
        srs-inst:sent-gp-a2-135-reduplication-of-verbs-002,
        srs-inst:sent-gp-a2-135-reduplication-of-verbs-003,
        srs-inst:sent-gp-a2-135-reduplication-of-verbs-004,
        srs-inst:sent-gp-a2-135-reduplication-of-verbs-005,
        srs-inst:sent-gp-a2-135-reduplication-of-verbs-006,
        srs-inst:sent-gp-a2-135-reduplication-of-verbs-007,
        srs-inst:sent-gp-a2-135-reduplication-of-verbs-008,
        srs-inst:sent-gp-a2-135-reduplication-of-verbs-009,
        srs-inst:sent-gp-a2-135-reduplication-of-verbs-010,
        srs-inst:sent-gp-a2-135-reduplication-of-verbs-011,
        srs-inst:sent-gp-a2-135-reduplication-of-verbs-012,
        srs-inst:sent-gp-a2-135-reduplication-of-verbs-013,
        srs-inst:sent-gp-a2-135-reduplication-of-verbs-014 ;
    srs-kg:structure "Single-syllable verbs: Verb + Verb (VV) or Verb + 一 + Verb (V一V). Two-syllable verbs: ABAB." .

srs-inst:gp-a1-038-expressing-ability-or-possibility-with-neng a srs-kg:GrammarPoint ;
    rdfs:label "Expressing ability or possibility with \"neng\""@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "能 (néng) is one of several Chinese words that is normally translated as \"can\" in English. However, 能 (néng) is used to emphasize one's ability or the possibility of something happening. 能 (néng) indicates ability when used with activities that are not consciously learned or studied. When used with activities that are consciously learned or studied, 能 (néng) generally means that circumstances do not allow execution of the action. In other words, it's not possible. Because 能 (néng) can express possibility, it is often used to form polite questions, something like \"would it be possible\" in English."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-001,
        srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-002,
        srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-003,
        srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-004,
        srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-005,
        srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-006,
        srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-007,
        srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-008,
        srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-009,
        srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-010,
        srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-011,
        srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-012,
        srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-013,
        srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-014,
        srs-inst:sent-gp-a1-038-expressing-ability-or-possibility-with-neng-015 ;
    srs-kg:structure "Subj. + 能 + Verb + Obj." .

srs-inst:gp-a2-082-superlative-zui a srs-kg:GrammarPoint ;
    rdfs:label "Superlative \"zui\""@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The most common way to form a superlative (best, worst, biggest, smallest, etc.) in Chinese is to use 最 (zuì) before an adjective (and a few select verbs). A 了 (le) is occasionally added after the adjective for emphasis. 最 (zuì) can also come before psychological verbs, to express what one \"most likes,\" \"most hates,\" etc. It won't make sense if you try to use 最 (zuì) with non-psychological verbs."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-082-superlative-zui-001,
        srs-inst:sent-gp-a2-082-superlative-zui-002,
        srs-inst:sent-gp-a2-082-superlative-zui-003,
        srs-inst:sent-gp-a2-082-superlative-zui-004,
        srs-inst:sent-gp-a2-082-superlative-zui-005,
        srs-inst:sent-gp-a2-082-superlative-zui-006,
        srs-inst:sent-gp-a2-082-superlative-zui-007,
        srs-inst:sent-gp-a2-082-superlative-zui-008,
        srs-inst:sent-gp-a2-082-superlative-zui-009,
        srs-inst:sent-gp-a2-082-superlative-zui-010,
        srs-inst:sent-gp-a2-082-superlative-zui-011,
        srs-inst:sent-gp-a2-082-superlative-zui-012,
        srs-inst:sent-gp-a2-082-superlative-zui-013,
        srs-inst:sent-gp-a2-082-superlative-zui-014,
        srs-inst:sent-gp-a2-082-superlative-zui-015 ;
    srs-kg:structure "最 + Adj. / Psychological Verb (+ 了)" .

srs-inst:gp-a2-112-sentence-final-interjection-a a srs-kg:GrammarPoint ;
    rdfs:label "Sentence-final interjection 'a'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The interjection 啊 (a) is often added to the end of sentences to add a tone of urgency, exclamation or excitement. The exact meaning often depends on context. It can be used to express exclamation, to add a sense of certainty or urgency, or with questions to add urgency or concern."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-112-sentence-final-interjection-a-001,
        srs-inst:sent-gp-a2-112-sentence-final-interjection-a-002,
        srs-inst:sent-gp-a2-112-sentence-final-interjection-a-003,
        srs-inst:sent-gp-a2-112-sentence-final-interjection-a-004,
        srs-inst:sent-gp-a2-112-sentence-final-interjection-a-005,
        srs-inst:sent-gp-a2-112-sentence-final-interjection-a-006,
