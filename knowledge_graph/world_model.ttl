    srs-kg:translationEN "When you are not here, I will miss you."@en .

srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-001 a srs-kg:Sentence ;
    rdfs:label "你不在的时候，我会想你。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou ;
    srs-kg:pinyin "Nǐ bù zài de shíhou, wǒ huì xiǎng nǐ." ;
    srs-kg:translationEN "When you are not here, I'll miss you."@en .

srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-002 a srs-kg:Sentence ;
    rdfs:label "我上大学的时候有很多女朋友。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou ;
    srs-kg:pinyin "Wǒ shàng dàxué de shíhou yǒu hěn duō nǚpéngyou." ;
    srs-kg:translationEN "When I was in college, I had a lot of girlfriends."@en .

srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-003 a srs-kg:Sentence ;
    rdfs:label "小的时候，我不喜欢吃肉。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou ;
    srs-kg:pinyin "Xiǎo de shíhou, wǒ bù xǐhuan chī ròu." ;
    srs-kg:translationEN "When I was little, I didn't like to eat meat."@en .

srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-004 a srs-kg:Sentence ;
    rdfs:label "老板工作的时候喜欢喝咖啡。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou ;
    srs-kg:pinyin "Lǎobǎn gōngzuò de shíhou xǐhuan hē kāfēi." ;
    srs-kg:translationEN "When the boss works, he likes to drink coffee."@en .

srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-005 a srs-kg:Sentence ;
    rdfs:label "我生气的时候请你不要笑。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou ;
    srs-kg:pinyin "Wǒ shēngqì de shíhou qǐng nǐ bùyào xiào." ;
    srs-kg:translationEN "Please don't laugh when I'm angry."@en .

srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-006 a srs-kg:Sentence ;
    rdfs:label "妈妈不在家的时候，我自己做饭。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou ;
    srs-kg:pinyin "Māma bù zài jiā de shíhou, wǒ zìjǐ zuòfàn." ;
    srs-kg:translationEN "When mom is not home, I cook for myself."@en .

srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-007 a srs-kg:Sentence ;
    rdfs:label "下课的时候，我们常常在一起聊天。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou ;
    srs-kg:pinyin "Xiàkè de shíhou, wǒmen chángcháng yīqǐ liáotiān." ;
    srs-kg:translationEN "We often chat after class."@en .

srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-008 a srs-kg:Sentence ;
    rdfs:label "吃东西的时候不要说话。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou ;
    srs-kg:pinyin "Chī dōngxi de shíhou bùyào shuōhuà." ;
    srs-kg:translationEN "Don't talk while eating."@en .

srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-009 a srs-kg:Sentence ;
    rdfs:label "你开车的时候会打电话吗？"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou ;
    srs-kg:pinyin "Nǐ kāichē de shíhou huì dǎ diànhuà ma?" ;
    srs-kg:translationEN "Do you talk on the phone when you're driving?"@en .

srs-inst:sent-gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou-010 a srs-kg:Sentence ;
    rdfs:label "走路的时候不要玩手机。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-091-when-with-%E7%9A%84%E6%97%B6%E5%80%99-de-sh%C3%ADhou ;
    srs-kg:pinyin "Zǒulù de shíhou bùyào wán shǒujī." ;
    srs-kg:translationEN "Don't play with your phone while walking."@en .

srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-001 a srs-kg:Sentence ;
    rdfs:label "下午三点以后，我不在家。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Xiàwǔ sāndiǎn yǐhòu, wǒ bù zài jiā." ;
    srs-kg:translationEN "After three p.m., I will not be at home."@en .

srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-002 a srs-kg:Sentence ;
    rdfs:label "来中国以后，她认识了她的老公。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Lái Zhōngguó yǐhòu, tā rènshi le tā de lǎogōng." ;
    srs-kg:translationEN "After coming to China, she met her husband."@en .

srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-003 a srs-kg:Sentence ;
    rdfs:label "她一个月以后开始上班。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Tā yī gè yuè yǐhòu kāishǐ shàngbān." ;
    srs-kg:translationEN "After one month, she will start working."@en .

srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-004 a srs-kg:Sentence ;
    rdfs:label "吃完午饭以后，我们要开会。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Chī wán wǔfàn yǐhòu, wǒmen yào kāihuì." ;
    srs-kg:translationEN "We are going to have a meeting after we finish lunch."@en .

srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-005 a srs-kg:Sentence ;
    rdfs:label "几年以后，我们公司会更大。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Jǐnián yǐhòu, wǒmen gōngsī huì gèng dà." ;
    srs-kg:translationEN "In a few years, our company will be even bigger."@en .

srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-006 a srs-kg:Sentence ;
    rdfs:label "老板半个小时以后回来。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Lǎobǎn bàn gè xiǎoshí yǐhòu huílái." ;
    srs-kg:translationEN "After half an hour, the boss will return."@en .

srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-007 a srs-kg:Sentence ;
    rdfs:label "下班以后你想跟我们一起去酒吧吗?"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Xiàbān yǐhòu, nǐ xiǎng gēn wǒmen yīqǐ qù jiǔbā ma?" ;
    srs-kg:translationEN "After we get off work, would you like to go to a bar with us?"@en .

srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-008 a srs-kg:Sentence ;
    rdfs:label "老板来了以后，大家都不说话了。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Lǎobǎn lái le yǐhòu, dàjiā dōu bù shuōhuà le." ;
    srs-kg:translationEN "After the boss came, everyone stopped talking."@en .

srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-009 a srs-kg:Sentence ;
    rdfs:label "你到家以后给我打电话。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Nǐ dào jiā yǐhòu gěi wǒ dǎ diànhuà." ;
    srs-kg:translationEN "After you get home, call me."@en .

srs-inst:sent-gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-010 a srs-kg:Sentence ;
    rdfs:label "生病以后爸爸不喝酒了。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-092-after-a-specific-time-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Shēngbìng yǐhòu, bàba bù hē jiǔ le." ;
    srs-kg:translationEN "After he got sick, dad stopped drinking."@en .

srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-001 a srs-kg:Sentence ;
    rdfs:label "吃饭以前，你洗手了吗？"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n ;
    srs-kg:pinyin "Chī fàn yǐqián, nǐ xǐ shǒu le ma?" ;
    srs-kg:translationEN "Did you wash your hands before eating?"@en .

srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-002 a srs-kg:Sentence ;
    rdfs:label "睡觉以前，不要吃东西。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n ;
    srs-kg:pinyin "Shuìjiào yǐqián, bù yào chī dōngxi." ;
    srs-kg:translationEN "Don't eat anything before you go to sleep."@en .

srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-003 a srs-kg:Sentence ;
    rdfs:label "两年以前，你认识他吗？"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n ;
    srs-kg:pinyin "Liǎngnián yǐqián, nǐ rènshi tā ma?" ;
    srs-kg:translationEN "Did you know him two years ago?"@en .

srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-004 a srs-kg:Sentence ;
    rdfs:label "星期五以前，你要做完这些工作。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n ;
    srs-kg:pinyin "Xīngqīwǔ yǐqián, nǐ yào zuò wán zhèxiē gōngzuò." ;
    srs-kg:translationEN "You need to finish this work before Friday."@en .

srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-005 a srs-kg:Sentence ;
    rdfs:label "上大学以前，你来过上海吗？"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n ;
    srs-kg:pinyin "Shàng dàxué yǐqián, nǐ lái guo shànghǎi ma?" ;
    srs-kg:translationEN "Before you went to college, did you ever come to Shanghai?"@en .

srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-006 a srs-kg:Sentence ;
    rdfs:label "结婚以前，你应该先买房子。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n ;
    srs-kg:pinyin "Jiéhūn yǐqián, nǐ yīnggāi xiān mǎi fángzi." ;
    srs-kg:translationEN "Before getting married, you should first buy a house."@en .

srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-007 a srs-kg:Sentence ;
    rdfs:label "二十年以前，这里是一个小村子。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n ;
    srs-kg:pinyin "Èrshí nián yǐqián, zhèlǐ shì yī gè xiǎo cūnzi." ;
    srs-kg:translationEN "Twenty years ago, this was a small village."@en .

srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-008 a srs-kg:Sentence ;
    rdfs:label "几个月以前，他们分手了。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n ;
    srs-kg:pinyin "Jǐ gè yuè yǐqián, tāmen fēnshǒu le." ;
    srs-kg:translationEN "They broke up a few months ago."@en .

srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-009 a srs-kg:Sentence ;
    rdfs:label "毕业以前，我要找到工作。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n ;
    srs-kg:pinyin "Bìyè yǐqián, wǒ yào zhǎodào gōngzuò." ;
    srs-kg:translationEN "I need to find a job before graduation."@en .

srs-inst:sent-gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n-010 a srs-kg:Sentence ;
    rdfs:label "当总统以前，Obama没有白头发。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-093-before-a-specific-time-with-%E4%BB%A5%E5%89%8D-y%C7%90qi%C3%A1n ;
    srs-kg:pinyin "Dāng zǒngtǒng yǐqián, Obama méiyǒu bái tóufa." ;
    srs-kg:translationEN "Before he became the president, Obama didn't have white hair ."@en .

srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-001 a srs-kg:Sentence ;
    rdfs:label "以后你们会想我吗？"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Yǐhòu nǐmen huì xiǎng wǒ ma?" ;
    srs-kg:translationEN "In the future, will you miss me?"@en .

srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-002 a srs-kg:Sentence ;
    rdfs:label "以后你想来中国吗？"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Yǐhòu nǐ xiǎng lái Zhōngguó ma?" ;
    srs-kg:translationEN "In the future, do you want to come to China?"@en .

srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-003 a srs-kg:Sentence ;
    rdfs:label "我以后不喝酒了。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Wǒ yǐhòu bù hē jiǔ le." ;
    srs-kg:translationEN "I will not drink alcohol in the future."@en .

srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-004 a srs-kg:Sentence ;
    rdfs:label "我们以后不在这里工作了。"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Wǒmen yǐhòu bù zài zhèlǐ gōngzuò le." ;
    srs-kg:translationEN "We will not work here in the future."@en .

srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-005 a srs-kg:Sentence ;
    rdfs:label "你儿子以后想做什么？"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Nǐ érzi yǐhòu xiǎng zuò shénme?" ;
    srs-kg:translationEN "In the future, what does your son want to do?"@en .

srs-inst:sent-gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u-006 a srs-kg:Sentence ;
    rdfs:label "以后你们想去哪儿工作？"@zh ;
    srs-kg:demonstratesGrammar srs-inst:gp-a2-094-in-the-future-in-general-with-%E4%BB%A5%E5%90%8E-y%C7%90h%C3%B2u ;
    srs-kg:pinyin "Yǐhòu nǐmen xiǎng qù nǎr gōngzuò?" ;
    srs-kg:translationEN "In the future, where would you like to work?"@en .

