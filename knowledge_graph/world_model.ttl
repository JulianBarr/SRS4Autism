        srs-kg:word-%E5%8E%BB ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29 ;
    srs-kg:pinyin "Tāmen yě huì qù ma?" ;
    srs-kg:translationEN "Are they also going?"@en .

srs-inst:sent-gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29-007 a srs-kg:Sentence ;
    rdfs:label "我 妈妈 也 喜欢 吃 水饺。"@zh ;
