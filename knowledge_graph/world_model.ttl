    srs-kg:pinyin "Xiǎoháizi xǐhuan yībiān chīfàn, yībiān wán." ;
    srs-kg:translationEN "Children like to eat while playing."@en .

srs-inst:sent-gp-a2-071-simultaneous-tasks-with-yibian-004 a srs-kg:Sentence ;
    rdfs:label "你喜欢一边听音乐，一边做作业吗？"@zh ;
    srs-kg:containsWord srs-kg:word-%E4%BD%A0,
