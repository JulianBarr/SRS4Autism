        srs-inst:sent-gp-a2-112-sentence-final-interjection-a-012,
        srs-inst:sent-gp-a2-112-sentence-final-interjection-a-013,
        srs-inst:sent-gp-a2-112-sentence-final-interjection-a-014,
        srs-inst:sent-gp-a2-112-sentence-final-interjection-a-015 ;
    srs-kg:structure "Sentence + 啊" .

srs-kg:word-pengyou a srs-kg:Word ;
    rdfs:label "朋友" ;
    srs-kg:composedOf srs-kg:char-peng,
        srs-kg:char-you ;
    srs-kg:definition "friend" ;
    srs-kg:hskLevel 1 ;
    srs-kg:means srs-kg:concept-friend ;
    srs-kg:partOfSpeech "noun" ;
    srs-kg:pinyin "péngyou" ;
    srs-kg:requiresPrerequisite srs-kg:char-peng,
        srs-kg:char-you ;
    srs-kg:text "朋友" .

srs-inst:gp-a1-009-negation-of-you-with-mei a srs-kg:GrammarPoint ;
    rdfs:label "Negation of \"you\" with \"mei\""@en ;
    srs-kg:cefrLevel "A1" ;
    srs-kg:explanation "The verb 有 (yǒu) is an exception to the standard negation rule and must be negated with 没 (méi) instead of 不 (bù). The phrase 没有 (méiyǒu) can also be shortened to just 没 (méi) without changing the meaning."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a1-009-negation-of-you-with-mei-001,
        srs-inst:sent-gp-a1-009-negation-of-you-with-mei-002,
