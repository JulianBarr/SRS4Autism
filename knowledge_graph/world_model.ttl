        srs-inst:sent-gp-a1-009-negation-of-you-with-mei-006,
        srs-inst:sent-gp-a1-009-negation-of-you-with-mei-007,
        srs-inst:sent-gp-a1-009-negation-of-you-with-mei-008,
        srs-inst:sent-gp-a1-009-negation-of-you-with-mei-009,
        srs-inst:sent-gp-a1-009-negation-of-you-with-mei-010,
        srs-inst:sent-gp-a1-009-negation-of-you-with-mei-011,
        srs-inst:sent-gp-a1-009-negation-of-you-with-mei-012,
