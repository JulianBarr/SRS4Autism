    srs-kg:pinyin "A: Wǒ shì Měiguó rén. B: Wǒ yě shì." ;
    srs-kg:translationEN "A: I am an American. B: Me too. / I am too."@en .

srs-inst:sent-gp-a1-011-the-also-adverb-ye-%E4%B9%9F-026 a srs-kg:Sentence ;
