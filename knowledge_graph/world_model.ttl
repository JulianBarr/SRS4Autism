    srs-kg:pinyin "Nǐ zhīdao Shànghǎi de fángzi duō guì ma?" ;
    srs-kg:translationEN "Do you know how expensive housing is in Shanghai?"@en .

srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-001 a srs-kg:Sentence ;
