srs-inst:gp-a2-062-expressing-already-with-yijing a srs-kg:GrammarPoint ;
    rdfs:label "Expressing 'already' with 'yijing'"@en ;
    srs-kg:cefrLevel "A2" ;
    srs-kg:explanation "The pattern 已经...了 (yǐjīng... le) is used to express 'already'. The particle 了 at the end is important for natural-sounding Chinese. The negative form, 已经不...了, is usually translated as 'not... anymore'."@en ;
    srs-kg:hasExample srs-inst:sent-gp-a2-062-expressing-already-with-yijing-001,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-002,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-003,
        srs-inst:sent-gp-a2-062-expressing-already-with-yijing-004,
