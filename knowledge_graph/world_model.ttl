    srs-kg:demonstratesGrammar srs-inst:gp-a2-073-basic-comparisons-with-yiyang ;
    srs-kg:pinyin "Zhè ge cí de yìsi hé nà ge cí yīyàng ma?" ;
    srs-kg:translationEN "Is the meaning of this word and that word the same?"@en .

srs-inst:sent-gp-a2-073-basic-comparisons-with-yiyang-005 a srs-kg:Sentence ;
    rdfs:label "美国文化跟中国文化不一样。"@zh ;
