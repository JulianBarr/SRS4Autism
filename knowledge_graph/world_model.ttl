    srs-kg:pinyin "Wǒ māma yě xǐhuan chī shuǐjiǎo." ;
    srs-kg:translationEN "My mother likes to eat boiled dumplings too."@en .

srs-inst:sent-gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29-008 a srs-kg:Sentence ;
    rdfs:label "小孩 也 可以 喝 酒 吗？"@zh ;
    srs-kg:containsWord srs-kg:word-%E5%8F%AF%E4%BB%A5 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29 ;
    srs-kg:pinyin "Xiǎohái yě kěyǐ hē jiǔ ma?" ;
    srs-kg:translationEN "Can kids drink alcohol too?"@en .

srs-inst:sent-gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29-009 a srs-kg:Sentence ;
    rdfs:label "你 也 想 来 我 家 吗？"@zh ;
    srs-kg:containsWord srs-kg:word-%E4%BD%A0 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29 ;
    srs-kg:pinyin "Nǐ yě xiǎng lái wǒ jiā ma?" ;
    srs-kg:translationEN "Do you want to come to my house too?"@en .

srs-inst:sent-gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29-010 a srs-kg:Sentence ;
    rdfs:label "她 也 觉得 这 个 老师 不 好。"@zh ;
    srs-kg:containsWord srs-kg:word-%E5%A5%B9,
        srs-kg:word-%E8%80%81%E5%B8%88,
        srs-kg:word-%E8%BF%99%E4%B8%AA ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29 ;
    srs-kg:pinyin "Tā yě juéde zhè ge lǎoshī bù hǎo." ;
    srs-kg:translationEN "She also thinks this teacher isn't good."@en .

srs-inst:sent-gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29-011 a srs-kg:Sentence ;
    rdfs:label "我 也 不 喜欢。"@zh ;
    srs-kg:containsWord srs-kg:word-%E5%96%9C%E6%AC%A2,
        srs-kg:word-%E6%88%91 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29 ;
    srs-kg:pinyin "Wǒ yě bù xǐhuan." ;
    srs-kg:translationEN "I don't like it either."@en .

srs-inst:sent-gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29-012 a srs-kg:Sentence ;
    rdfs:label "我 也 不 知道。"@zh ;
    srs-kg:containsWord srs-kg:word-%E6%88%91 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29 ;
    srs-kg:pinyin "Wǒ yě bù zhīdao." ;
    srs-kg:translationEN "I don't know either."@en .

srs-inst:sent-gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29-013 a srs-kg:Sentence ;
    rdfs:label "他 也 没 有。"@zh ;
    srs-kg:containsWord srs-kg:word-%E4%BB%96 ;
    srs-kg:demonstratesGrammar srs-inst:gp-a1-011-The%20%27also%27%20adverb%20%27ye%27%20%28%E4%B9%9F%29 ;
    srs-kg:pinyin "Tā yě méi yǒu." ;
    srs-kg:translationEN "He doesn't have it either."@en .

