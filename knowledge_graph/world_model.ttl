    srs-kg:pinyin "Zhè ge wènti yě hěn máfan." ;
    srs-kg:translationEN "This problem is also very troublesome."@en .

srs-inst:sent-gp-a1-011-the-also-adverb-ye-%E4%B9%9F-024 a srs-kg:Sentence ;
    rdfs:label "我 觉得 这 个 餐厅 也 很 好 。"@zh ;
