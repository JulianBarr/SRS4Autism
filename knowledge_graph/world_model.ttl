    srs-kg:pinyin "Běijīng xià yǔ le. Shànghǎi ne?" ;
    srs-kg:translationEN "It's raining in Beijing. How about Shanghai?"@en .

srs-inst:sent-gp-a1-003-forming-what-about-questions-with-ne-%E5%91%A2-003 a srs-kg:Sentence ;
    rdfs:label "你 说 他们 可以 去 。 我们 呢？"@zh ;
