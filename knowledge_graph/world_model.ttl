    srs-kg:translationEN "Don't talk while eating."@en .

srs-inst:sent-gp-a2-091-When%20with%20%E7%9A%84%E6%97%B6%E5%80%99%20%28de%20sh%C3%ADhou%29-009 a srs-kg:Sentence ;
